@page
@model HealthyRecipes.Web.Areas.Admin.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="page-header" style="margin-bottom: 32px;">
    <h1 style="font-size: 2rem; color: var(--admin-primary); margin: 0;">Reports & Analytics</h1>
    <p style="color: #666; margin-top: 8px;">Platform statistics and insights</p>
</div>

<!-- User Statistics -->
<div class="admin-card" style="margin-bottom: 24px;">
    <h2 style="font-size: 1.25rem; margin-bottom: 20px; color: var(--admin-primary);">👥 User Statistics</h2>
    
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        <div class="stat-box">
            <div class="stat-label">Total Users</div>
            <div class="stat-number">@Model.TotalUsers</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Active Users</div>
            <div class="stat-number" style="color: var(--admin-secondary);">@Model.ActiveUsers</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Deleted Users</div>
            <div class="stat-number" style="color: var(--admin-danger);">@Model.DeletedUsers</div>
        </div>
    </div>
</div>

<!-- Recipe Statistics -->
<div class="admin-card" style="margin-bottom: 24px;">
    <h2 style="font-size: 1.25rem; margin-bottom: 20px; color: var(--admin-primary);">🍳 Recipe Statistics</h2>
    
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        <div class="stat-box">
            <div class="stat-label">Total Recipes</div>
            <div class="stat-number">@Model.TotalRecipes</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Active Recipes</div>
            <div class="stat-number" style="color: var(--admin-secondary);">@Model.ActiveRecipes</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Deleted Recipes</div>
            <div class="stat-number" style="color: var(--admin-danger);">@Model.DeletedRecipes</div>
        </div>
    </div>
</div>

<!-- Content Statistics -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <div class="admin-card">
        <h2 style="font-size: 1.25rem; margin-bottom: 20px; color: var(--admin-primary);">📅 Meal Plans</h2>
        <div class="stat-box">
            <div class="stat-label">Total Meal Plans</div>
            <div class="stat-number">@Model.TotalMealPlans</div>
        </div>
    </div>

    <div class="admin-card">
        <h2 style="font-size: 1.25rem; margin-bottom: 20px; color: var(--admin-primary);">💬 Engagement</h2>
        <div class="stat-box">
            <div class="stat-label">Total Comments & Ratings</div>
            <div class="stat-number">@Model.TotalComments</div>
        </div>
    </div>
</div>

<!-- Monthly Trends -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
    <div class="admin-card">
        <h2 style="font-size: 1.25rem; margin-bottom: 20px; color: var(--admin-primary);">📈 User Growth (Last 6 Months)</h2>
        
        @if (Model.UsersByMonth.Any())
        {
            <div style="display: flex; flex-direction: column; gap: 12px;">
                @foreach (var month in Model.UsersByMonth.OrderByDescending(m => m.Key))
                {
                    var maxCount = Model.UsersByMonth.Values.Max();
                    var percentage = maxCount > 0 ? (month.Value * 100.0 / maxCount) : 0;
                    
                    <div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                            <span style="font-size: 0.875rem; color: #666;">@DateTime.ParseExact(month.Key, "yyyy-MM", null).ToString("MMM yyyy")</span>
                            <span style="font-size: 0.875rem; font-weight: 600;">@month.Value users</span>
                        </div>
                        <div style="height: 8px; background: var(--admin-bg); border-radius: 4px; overflow: hidden;">
                            <div style="height: 100%; background: var(--admin-primary); width: @percentage%"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #666; font-size: 0.9rem;">No data available</p>
        }
    </div>

    <div class="admin-card">
        <h2 style="font-size: 1.25rem; margin-bottom: 20px; color: var(--admin-primary);">📈 Recipe Creation (Last 6 Months)</h2>
        
        @if (Model.RecipesByMonth.Any())
        {
            <div style="display: flex; flex-direction: column; gap: 12px;">
                @foreach (var month in Model.RecipesByMonth.OrderByDescending(m => m.Key))
                {
                    var maxCount = Model.RecipesByMonth.Values.Max();
                    var percentage = maxCount > 0 ? (month.Value * 100.0 / maxCount) : 0;
                    
                    <div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                            <span style="font-size: 0.875rem; color: #666;">@DateTime.ParseExact(month.Key, "yyyy-MM", null).ToString("MMM yyyy")</span>
                            <span style="font-size: 0.875rem; font-weight: 600;">@month.Value recipes</span>
                        </div>
                        <div style="height: 8px; background: var(--admin-bg); border-radius: 4px; overflow: hidden;">
                            <div style="height: 100%; background: var(--admin-secondary); width: @percentage%"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #666; font-size: 0.9rem;">No data available</p>
        }
    </div>
</div>

<style>
    .stat-box {
        padding: 20px;
        background: var(--admin-bg);
        border-radius: 8px;
        text-align: center;
    }

    .stat-label {
        font-size: 0.875rem;
        color: #666;
        margin-bottom: 8px;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--admin-primary);
    }
</style>
