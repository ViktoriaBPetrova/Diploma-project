@page
@model HealthyRecipes.Web.Areas.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<div class="page-header" style="margin-bottom: 32px;">
    <h1 style="font-size: 2rem; color: var(--admin-primary); margin: 0;">User Management</h1>
    <p style="color: #666; margin-top: 8px;">Manage all registered users</p>
</div>

<div class="admin-card" style="margin-bottom: 24px;">
    <form method="get">
        <div style="display: flex; gap: 12px; align-items: center;">
            <input 
                type="text" 
                name="SearchTerm" 
                value="@Model.SearchTerm"
                placeholder="Search by username, email, or name..." 
                style="flex: 1; padding: 10px 16px; border: 1px solid var(--admin-border); border-radius: 6px; font-size: 0.95rem;"
            />
            <button type="submit" class="btn-primary" style="padding: 10px 24px; white-space: nowrap;">
                🔍 Search
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-page="/Users/Index" class="btn-ghost-sm">Clear</a>
            }
        </div>
    </form>
</div>

<div class="admin-card">
    <div style="margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center;">
        <h2 style="font-size: 1.25rem; margin: 0; color: var(--admin-primary);">
            Users (@Model.Users.Count)
        </h2>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Name</th>
                <th>Recipes</th>
                <th>Meal Plans</th>
                <th>Joined</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Users.Any())
            {
                @foreach (var user in Model.Users)
                {
                    <tr style="@(user.IsDeleted ? "opacity: 0.5;" : "")">
                        <td>
                            <strong>@user.UserName</strong>
                        </td>
                        <td>@user.Email</td>
                        <td>@(user.FirstName ?? "") @(user.LastName ?? "")</td>
                        <td style="text-align: center;">@user.RecipeCount</td>
                        <td style="text-align: center;">@user.MealPlanCount</td>
                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (user.IsDeleted)
                            {
                                <span class="status-badge status-deleted">Deleted</span>
                            }
                            else
                            {
                                <span class="status-badge status-active">Active</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <a asp-page="/Users/Details" asp-route-id="@user.Id" class="btn-action">
                                    View
                                </a>
                                @if (!user.IsDeleted)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" style="display: inline;">
                                        <button type="submit" class="btn-action btn-danger" onclick="return confirm('Are you sure you want to delete this user?');">
                                            Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Restore" asp-route-id="@user.Id" style="display: inline;">
                                        <button type="submit" class="btn-action btn-success">
                                            Restore
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" style="text-align: center; padding: 32px; color: #666;">
                        No users found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .btn-primary {
        background: var(--admin-primary);
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background: var(--admin-secondary);
        transform: translateY(-1px);
    }

    .btn-action {
        padding: 6px 12px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        border: 1px solid var(--admin-border);
        background: white;
        color: var(--admin-text);
        cursor: pointer;
        transition: all 0.2s;
        display: inline-block;
    }

    .btn-action:hover {
        background: var(--admin-bg);
        border-color: var(--admin-primary);
        color: var(--admin-primary);
    }

    .btn-danger {
        border-color: #ffdddd;
        color: var(--admin-danger);
    }

    .btn-danger:hover {
        background: #fff5f5;
        border-color: var(--admin-danger);
    }

    .btn-success {
        border-color: #d4ecd4;
        color: var(--admin-secondary);
    }

    .btn-success:hover {
        background: #f0f8f0;
        border-color: var(--admin-secondary);
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-active {
        background: #d4ecd4;
        color: #2d5016;
    }

    .status-deleted {
        background: #ffdddd;
        color: var(--admin-danger);
    }
</style>
