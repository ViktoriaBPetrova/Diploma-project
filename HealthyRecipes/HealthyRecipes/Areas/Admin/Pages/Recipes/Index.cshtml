@page
@model HealthyRecipes.Web.Areas.Admin.Pages.Recipes.IndexModel
@{
    ViewData["Title"] = "Recipe Management";
}

<div class="page-header" style="margin-bottom: 32px;">
    <h1 style="font-size: 2rem; color: var(--admin-primary); margin: 0;">Recipe Management</h1>
    <p style="color: #666; margin-top: 8px;">Review and moderate recipes</p>
</div>

<div class="admin-card" style="margin-bottom: 24px;">
    <form method="get">
        <div style="display: grid; grid-template-columns: 1fr auto auto auto; gap: 12px; align-items: center;">
            <input 
                type="text" 
                name="SearchTerm" 
                value="@Model.SearchTerm"
                placeholder="Search by recipe name or description..." 
                style="padding: 10px 16px; border: 1px solid var(--admin-border); border-radius: 6px; font-size: 0.95rem;"
            />
            
            <select name="Status" style="padding: 10px 16px; border: 1px solid var(--admin-border); border-radius: 6px; font-size: 0.95rem;">
                <option value="all" selected="@(Model.Status == "all")">All Recipes</option>
                <option value="active" selected="@(Model.Status == "active")">Active Only</option>
                <option value="deleted" selected="@(Model.Status == "deleted")">Deleted Only</option>
            </select>
            
            <button type="submit" class="btn-primary" style="padding: 10px 24px; white-space: nowrap;">
                🔍 Search
            </button>
            
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.Status != "all")
            {
                <a asp-page="/Recipes/Index" class="btn-ghost-sm">Clear</a>
            }
        </div>
    </form>
</div>

<div class="admin-card">
    <div style="margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center;">
        <h2 style="font-size: 1.25rem; margin: 0; color: var(--admin-primary);">
            Recipes (@Model.Recipes.Count)
        </h2>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>Recipe</th>
                <th>Author</th>
                <th>Calories</th>
                <th>Time</th>
                <th>Difficulty</th>
                <th>Created</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Recipes.Any())
            {
                @foreach (var recipe in Model.Recipes)
                {
                    <tr style="@(recipe.IsDeleted ? "opacity: 0.5;" : "")">
                        <td>
                            <div>
                                <strong>@recipe.Title</strong>
                                @if (!string.IsNullOrWhiteSpace(recipe.Info))
                                {
                                    <div style="font-size: 0.85rem; color: #666; margin-top: 2px;">
                                        @(recipe.Info.Length > 80 ? recipe.Info.Substring(0, 80) + "..." : recipe.Info)
                                    </div>
                                }
                            </div>
                        </td>
                        <td>@recipe.AuthorName</td>
                        <td>@(recipe.Calories?.ToString("0") ?? "N/A")</td>
                        <td>@(recipe.PrepTime?.ToString() ?? "N/A") min</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(recipe.Difficulty))
                            {
                                <span class="difficulty-badge difficulty-@recipe.Difficulty.ToLower()">
                                    @recipe.Difficulty
                                </span>
                            }
                        </td>
                        <td>@recipe.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (recipe.IsDeleted)
                            {
                                <span class="status-badge status-deleted">Deleted</span>
                            }
                            else
                            {
                                <span class="status-badge status-active">Active</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id" asp-area="" class="btn-action" target="_blank">
                                    View
                                </a>
                                @if (!recipe.IsDeleted)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.Id" style="display: inline;">
                                        <button type="submit" class="btn-action btn-danger" onclick="return confirm('Are you sure you want to delete this recipe?');">
                                            Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Restore" asp-route-id="@recipe.Id" style="display: inline;">
                                        <button type="submit" class="btn-action btn-success">
                                            Restore
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" style="text-align: center; padding: 32px; color: #666;">
                        No recipes found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .btn-primary {
        background: var(--admin-primary);
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background: var(--admin-secondary);
        transform: translateY(-1px);
    }

    .btn-action {
        padding: 6px 12px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        border: 1px solid var(--admin-border);
        background: white;
        color: var(--admin-text);
        cursor: pointer;
        transition: all 0.2s;
        display: inline-block;
    }

    .btn-action:hover {
        background: var(--admin-bg);
        border-color: var(--admin-primary);
        color: var(--admin-primary);
    }

    .btn-danger {
        border-color: #ffdddd;
        color: var(--admin-danger);
    }

    .btn-danger:hover {
        background: #fff5f5;
        border-color: var(--admin-danger);
    }

    .btn-success {
        border-color: #d4ecd4;
        color: var(--admin-secondary);
    }

    .btn-success:hover {
        background: #f0f8f0;
        border-color: var(--admin-secondary);
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-active {
        background: #d4ecd4;
        color: #2d5016;
    }

    .status-deleted {
        background: #ffdddd;
        color: var(--admin-danger);
    }

    .difficulty-badge {
        padding: 3px 10px;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }

    .difficulty-easy {
        background: #d4ecd4;
        color: #2d5016;
    }

    .difficulty-medium {
        background: #ffeaa7;
        color: #b8860b;
    }

    .difficulty-hard {
        background: #ffdddd;
        color: #c84b31;
    }
</style>
