@page
@model HealthyRecipes.Web.Areas.Admin.Pages.ActivityLogs.IndexModel
@using HealthyRecipes.Data.Entities.Admin
@{
    ViewData["Title"] = "Activity Logs";
}

<div class="page-header">
    <h1>Activity Logs</h1>
    <p>Track all system activities and user actions</p>
</div>

<div class="admin-card" style="margin-bottom: 24px;">
    <h3>Filters</h3>
    <form method="get" class="filter-form">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
            <div class="form-group">
                <label>Activity Type</label>
                <select name="activityType" class="form-control">
                    <option value="">All Types</option>
                    @foreach (ActivityType type in Enum.GetValues(typeof(ActivityType)))
                    {
                        <option value="@((int)type)" selected="@(Model.ViewModel.Filter.ActivityType == type)">
                            @type.ToString()
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Entity Type</label>
                <select name="entityType" class="form-control">
                    <option value="">All Entities</option>
                    <option value="Recipe" selected="@(Model.ViewModel.Filter.EntityType == "Recipe")">Recipe</option>
                    <option value="MealPlan" selected="@(Model.ViewModel.Filter.EntityType == "MealPlan")">Meal Plan</option>
                    <option value="User" selected="@(Model.ViewModel.Filter.EntityType == "User")">User</option>
                    <option value="Comment" selected="@(Model.ViewModel.Filter.EntityType == "Comment")">Comment</option>
                    <option value="Ingredient" selected="@(Model.ViewModel.Filter.EntityType == "Ingredient")">Ingredient</option>
                    <option value="Category" selected="@(Model.ViewModel.Filter.EntityType == "Category")">Category</option>
                </select>
            </div>

            <div class="form-group">
                <label>Severity</label>
                <select name="severity" class="form-control">
                    <option value="">All Severities</option>
                    @foreach (LogSeverity severity in Enum.GetValues(typeof(LogSeverity)))
                    {
                        <option value="@((int)severity)" selected="@(Model.ViewModel.Filter.Severity == severity)">
                            @severity.ToString()
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>From Date</label>
                <input type="date" name="fromDate" class="form-control" value="@Model.ViewModel.Filter.FromDate?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="form-group">
                <label>To Date</label>
                <input type="date" name="toDate" class="form-control" value="@Model.ViewModel.Filter.ToDate?.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div style="margin-top: 16px; display: flex; gap: 12px;">
            <button type="submit" class="btn-primary">Apply Filters</button>
            <a asp-page="/ActivityLogs/Index" class="btn-ghost">Clear Filters</a>
        </div>
    </form>
</div>

<div class="admin-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3>Activity Log Entries (@Model.ViewModel.TotalCount total)</h3>
    </div>

    @if (Model.ViewModel.Logs.Any())
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Date/Time</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Details</th>
                    <th>Severity</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.ViewModel.Logs)
                {
                    <tr>
                        <td style="white-space: nowrap;">
                            @log.CreatedAt.ToString("MMM dd, yyyy")
                            <div style="font-size: 0.85rem; color: #666;">@log.CreatedAt.ToString("HH:mm:ss")</div>
                        </td>
                        <td>
                            <div>@log.UserName</div>
                            <div style="font-size: 0.85rem; color: #666;">@log.UserEmail</div>
                        </td>
                        <td>
                            <strong>@log.ActivityTypeDisplay</strong>
                        </td>
                        <td>
                            <div>@log.EntityType</div>
                            <div style="font-size: 0.85rem; color: #666;">@log.EntityName</div>
                        </td>
                        <td style="max-width: 300px;">
                            @if (!string.IsNullOrEmpty(log.ChangesSummary))
                            {
                                <div style="font-size: 0.9rem;">@log.ChangesSummary</div>
                            }
                            else
                            {
                                <span style="color: #999;">—</span>
                            }
                        </td>
                        <td>
                            <span class="status-badge @log.SeverityBadgeClass">
                                @log.SeverityDisplay
                            </span>
                        </td>
                        <td>
                            @(log.IpAddress ?? "—")
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.ViewModel.TotalPages > 1)
        {
            <div class="pagination" style="margin-top: 24px;">
                @if (Model.ViewModel.CurrentPage > 1)
                {
                    <a asp-page="/ActivityLogs/Index" 
                       asp-route-page="@(Model.ViewModel.CurrentPage - 1)"
                       asp-route-activityType="@Model.ViewModel.Filter.ActivityType"
                       asp-route-entityType="@Model.ViewModel.Filter.EntityType"
                       asp-route-severity="@Model.ViewModel.Filter.Severity"
                       asp-route-fromDate="@Model.ViewModel.Filter.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.ViewModel.Filter.ToDate?.ToString("yyyy-MM-dd")"
                       class="pagination-btn">← Previous</a>
                }

                <span class="pagination-info">
                    Page @Model.ViewModel.CurrentPage of @Model.ViewModel.TotalPages
                </span>

                @if (Model.ViewModel.CurrentPage < Model.ViewModel.TotalPages)
                {
                    <a asp-page="/ActivityLogs/Index" 
                       asp-route-page="@(Model.ViewModel.CurrentPage + 1)"
                       asp-route-activityType="@Model.ViewModel.Filter.ActivityType"
                       asp-route-entityType="@Model.ViewModel.Filter.EntityType"
                       asp-route-severity="@Model.ViewModel.Filter.Severity"
                       asp-route-fromDate="@Model.ViewModel.Filter.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.ViewModel.Filter.ToDate?.ToString("yyyy-MM-dd")"
                       class="pagination-btn">Next →</a>
                }
            </div>
        }
    }
    else
    {
        <p style="text-align: center; color: #666; padding: 40px;">No activity logs found matching your filters.</p>
    }
</div>
