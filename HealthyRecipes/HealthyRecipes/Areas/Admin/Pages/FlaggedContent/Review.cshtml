@page
@model HealthyRecipes.Web.Areas.Admin.Pages.FlaggedContent.ReviewModel
@using HealthyRecipes.Data.Entities.Admin
@{
    ViewData["Title"] = "Review Flagged Content";
}

<div class="page-header">
    <a asp-page="/FlaggedContent/Index" class="back-link">← Back to Flagged Content</a>
    <h1>Review Flagged Content</h1>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
    <!-- Main Content Column -->
    <div>
        <!-- Content Details -->
        <div class="admin-card" style="margin-bottom: 24px;">
            <h3>Content Details</h3>

            <div class="detail-row">
                <span class="detail-label">Content Type:</span>
                <span class="badge-sm">@Model.ViewModel.ContentType</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Content ID:</span>
                <code>@Model.ViewModel.ContentId</code>
            </div>

            <div class="detail-row">
                <span class="detail-label">Flagged Date:</span>
                <span>@Model.ViewModel.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Status:</span>
                <span class="status-badge @(Model.ViewModel.Status == FlagStatus.Pending ? "status-pending" : "status-resolved")">
                    @Model.ViewModel.Status
                </span>
            </div>
        </div>

        <!-- Content Preview -->
        <div class="admin-card" style="margin-bottom: 24px;">
            <h3>Content Preview</h3>
            <div style="background: #f9fafb; padding: 16px; border-radius: 8px; border-left: 4px solid #dc2626;">
                <p style="margin: 0; white-space: pre-wrap;">@Model.ViewModel.ContentPreview</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ViewModel.MatchedBannedWords))
            {
                <div style="margin-top: 12px; padding: 12px; background: #fef2f2; border-radius: 6px;">
                    <strong style="color: #dc2626;">🚫 Matched Banned Words:</strong>
                    <div style="margin-top: 4px;">
                        @foreach (var word in Model.ViewModel.MatchedBannedWords.Split(','))
                        {
                            <span class="badge-danger" style="margin-right: 8px;">@word.Trim()</span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Flag Details -->
        <div class="admin-card" style="margin-bottom: 24px;">
            <h3>Flag Details</h3>

            <div class="detail-row">
                <span class="detail-label">Reason:</span>
                <strong style="color: #dc2626;">@Model.ViewModel.Reason</strong>
            </div>

            @if (!string.IsNullOrEmpty(Model.ViewModel.Details))
            {
                <div class="detail-row">
                    <span class="detail-label">Additional Details:</span>
                    <span>@Model.ViewModel.Details</span>
                </div>
            }

            <div class="detail-row">
                <span class="detail-label">Reported By:</span>
                <span>
                    @if (string.IsNullOrEmpty(Model.ViewModel.ReportedByUserName))
                    {
                        <em style="color: #666;">Auto-flagged by system</em>
                    }
                    else
                    {
                        @Model.ViewModel.ReportedByUserName
                    }
                </span>
            </div>
        </div>

        <!-- Resolution Actions (only if pending) -->
        @if (Model.ViewModel.Status == FlagStatus.Pending)
        {
            <div class="admin-card">
                <h3>Take Action</h3>

                <form method="post" asp-page-handler="Resolve">
                    <input type="hidden" asp-for="Input.Id" />

                    <div class="form-group">
                        <label asp-for="Input.Resolution">Resolution Action <span style="color: #dc2626;">*</span></label>
                        <select asp-for="Input.Resolution" class="form-control" required id="resolutionSelect">
                            <option value="">Select action...</option>
                            <option value="@((int)FlagResolution.ContentRemoved)">🗑️ Remove Content (soft delete)</option>
                            <option value="@((int)FlagResolution.ContentEdited)">✏️ Edit Content (navigate to edit page)</option>
                            <option value="@((int)FlagResolution.UserWarned)">⚠️ Warn User Only</option>
                            <option value="@((int)FlagResolution.NoActionNeeded)">✓ No Action Needed</option>
                        </select>
                    </div>

                    <!-- Action Explanations -->
                    <div id="actionExplanation" style="display: none; padding: 12px; background: #f0f9ff; border-left: 3px solid #3b82f6; margin-bottom: 16px; border-radius: 4px;">
                        <div id="explainRemove" style="display: none;">
                            <strong>Remove Content:</strong> The content will be <strong>soft deleted</strong> (hidden from users but preserved in database). This happens automatically when you click Resolve.
                        </div>
                        <div id="explainEdit" style="display: none;">
                            <strong>Edit Content:</strong> After resolving, you'll be redirected to the edit page where you can modify the content to remove inappropriate parts.
                        </div>
                        <div id="explainWarn" style="display: none;">
                            <strong>Warn User Only:</strong> The content stays visible, but the user receives a warning. Enable the checkbox below to issue the warning.
                        </div>
                        <div id="explainNoAction" style="display: none;">
                            <strong>No Action Needed:</strong> The content is fine (false positive). The flag will be marked as resolved with no changes.
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.AdminNotes">Admin Notes (optional)</label>
                        <textarea asp-for="Input.AdminNotes" class="form-control" rows="3"
                                  placeholder="Internal notes about this resolution..."></textarea>
                    </div>

                    <div class="form-group">
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                            <input type="checkbox" asp-for="Input.IssueWarning" id="issueWarningCheck" />
                            <span>Issue warning to content author</span>
                        </label>
                        <small class="form-text" style="margin-left: 28px; color: #666;">
                            Recommended for "Warn User Only" or when content is removed
                        </small>
                    </div>

                    <div id="warning-fields" style="display: none; margin-left: 28px; padding: 12px; background: #fef3c7; border-radius: 6px;">
                        <div class="form-group">
                            <label asp-for="Input.WarningType">Warning Type</label>
                            <select asp-for="Input.WarningType" class="form-control">
                                @foreach (WarningType type in Enum.GetValues(typeof(WarningType)))
                                {
                                    <option value="@((int)type)">@type.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label asp-for="Input.WarningReason">Warning Reason</label>
                            <input asp-for="Input.WarningReason" class="form-control" placeholder="E.g., Use of inappropriate language" />
                        </div>
                    </div>

                    <div style="display: flex; gap: 12px; margin-top: 24px;">
                        <button type="submit" class="btn-primary">✓ Resolve & Execute Action</button>
                        <button type="button" class="btn-ghost" onclick="dismissFlag()">Dismiss as False Positive</button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <!-- Already Resolved -->
            <div class="admin-card">
                <h3>Resolution</h3>
                <div class="detail-row">
                    <span class="detail-label">Resolution:</span>
                    <strong>@Model.ViewModel.Resolution</strong>
                </div>
                @if (!string.IsNullOrEmpty(Model.ViewModel.AdminNotes))
                {
                    <div class="detail-row">
                        <span class="detail-label">Admin Notes:</span>
                        <span>@Model.ViewModel.AdminNotes</span>
                    </div>
                }
                @if (Model.ViewModel.ReviewedAt.HasValue)
                {
                    <div class="detail-row">
                        <span class="detail-label">Reviewed:</span>
                        <span>@Model.ViewModel.ReviewedAt.Value.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Sidebar Column -->
    <div>
        <!-- Author Info -->
        <div class="admin-card" style="margin-bottom: 24px;">
            <h3>Content Author</h3>

            <div style="margin-bottom: 12px;">
                <div style="font-weight: 600; font-size: 1.1rem;">@Model.ViewModel.ContentAuthorName</div>
                <div style="color: #666; font-size: 0.9rem;">@Model.ViewModel.ContentAuthorEmail</div>
            </div>

            <div style="padding: 12px; background: #f9fafb; border-radius: 6px; margin-bottom: 12px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="color: #666;">Active Warnings:</span>
                    <strong style="color: @(Model.ViewModel.AuthorActiveWarnings > 0 ? "#dc2626" : "#10b981");">
                        @Model.ViewModel.AuthorActiveWarnings
                    </strong>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #666;">Total Flags:</span>
                    <strong>@Model.ViewModel.AuthorTotalFlags</strong>
                </div>
            </div>

            <a asp-controller="User" asp-action="Profile" asp-route-id="@Model.ViewModel.ContentAuthorId"
               class="btn-ghost" style="width: 100%; text-align: center;">
                View Full Profile →
            </a>
        </div>

        <!-- Quick Actions -->
        <div class="admin-card">
            <h3>Quick Links</h3>

            <a asp-page="/ActivityLogs/Index" asp-route-userId="@Model.ViewModel.ContentAuthorId"
               class="action-link">📊 View User Activity</a>

            @if (!string.IsNullOrEmpty(Model.ViewInContextUrl))
            {
                <a href="@Model.ViewInContextUrl" class="action-link" target="_blank">
                    🔗 View in Context
                </a>
            }
            else
            {
                <div class="action-link" style="opacity: 0.5; cursor: not-allowed;">
                    🔗 View in Context (unavailable)
                </div>
            }
        </div>
    </div>
</div>

<!-- Hidden form for dismiss action -->
<form id="dismissForm" method="post" asp-page-handler="Dismiss" style="display: none;">
    <input type="hidden" name="id" value="@Model.ViewModel.Id" />
    <input type="hidden" name="adminNotes" id="dismissNotes" />
</form>

@section Scripts {
    <script>
        // Show/hide warning fields
        document.getElementById('issueWarningCheck').addEventListener('change', function() {
            document.getElementById('warning-fields').style.display = this.checked ? 'block' : 'none';
        });

        // Show explanation based on selected resolution
        document.getElementById('resolutionSelect').addEventListener('change', function() {
            const value = this.value;
            const explanationDiv = document.getElementById('actionExplanation');

            // Hide all explanations
            document.getElementById('explainRemove').style.display = 'none';
            document.getElementById('explainEdit').style.display = 'none';
            document.getElementById('explainWarn').style.display = 'none';
            document.getElementById('explainNoAction').style.display = 'none';

            if (value) {
                explanationDiv.style.display = 'block';

                // Show relevant explanation
                if (value == '@((int)FlagResolution.ContentRemoved)') {
                    document.getElementById('explainRemove').style.display = 'block';
                } else if (value == '@((int)FlagResolution.ContentEdited)') {
                    document.getElementById('explainEdit').style.display = 'block';
                } else if (value == '@((int)FlagResolution.UserWarned)') {
                    document.getElementById('explainWarn').style.display = 'block';
                } else if (value == '@((int)FlagResolution.NoActionNeeded)') {
                    document.getElementById('explainNoAction').style.display = 'block';
                }
            } else {
                explanationDiv.style.display = 'none';
            }
        });

        // Dismiss function
        function dismissFlag() {
            if (confirm('Dismiss this flag as a false positive?')) {
                const notes = prompt('Optional: Add a note about why this is being dismissed:');
                if (notes !== null) {
                    document.getElementById('dismissNotes').value = notes || '';
                    document.getElementById('dismissForm').submit();
                }
            }
        }
    </script>
}


