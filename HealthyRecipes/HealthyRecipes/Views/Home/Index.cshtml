@{
    ViewData["Title"] = "Home";
    var recipes = ViewBag.FeaturedRecipes as IEnumerable<HealthyRecipes.Web.ViewModels.Recipe.RecipeCardViewModel> ?? Enumerable.Empty<HealthyRecipes.Web.ViewModels.Recipe.RecipeCardViewModel>();
    var categories = ViewBag.Categories as IEnumerable<HealthyRecipes.Web.ViewModels.Recipe.CategoryFilterViewModel> ?? Enumerable.Empty<HealthyRecipes.Web.ViewModels.Recipe.CategoryFilterViewModel>();
}

<section class="hero">
    <div class="container">
        <div class="hero-eyebrow">🌿 Track · Plan · Thrive</div>
        <h1>Fuel your body<br /><em>the smart way</em></h1>
        <p>Discover healthy recipes, build personalised meal plans, and track your nutrition goals — all in one place.</p>
        <div class="hero-btns">
            <a asp-controller="Recipe" asp-action="Index" class="btn-primary">Browse recipes</a>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-area="Identity" asp-page="/Account/Register" class="btn-ghost">Create account</a>
            }
            else
            {
                <a asp-controller="MealPlan" asp-action="Index" class="btn-ghost">My meal plans</a>
            }
        </div>
    </div>
</section>

<section class="section inline-style-1">
    <div class="container">
        <div class="inline-style-2">
            <div>
                <div class="inline-style-3">150+</div>
                <div class="inline-style-4">Healthy recipes</div>
            </div>
            <div>
                <div class="inline-style-5">5</div>
                <div class="inline-style-6">Categories</div>
            </div>
            <div>
                <div class="inline-style-7">100%</div>
                <div class="inline-style-8">Macro tracked</div>
            </div>
        </div>
    </div>
</section>

@if (categories.Any())
{
    <section class="section">
        <div class="container">
            <h2 class="section-title">Browse by category</h2>
            <div class="filter-row">
                @foreach (var cat in categories)
                {
                    <a asp-controller="Recipe" asp-action="Index" asp-route-categoryId="@cat.Id" class="filter-pill">@cat.Name</a>
                }
                <a asp-controller="Recipe" asp-action="Index" class="filter-pill">All recipes →</a>
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="container">
        <div class="page-header-row inline-style-9">
            <h2 class="section-title inline-style-10">Featured Recipes</h2>
            <a asp-controller="Recipe" asp-action="Index" class="btn-ghost inline-style-11">View all →</a>
        </div>

        @if (recipes.Any())
        {
            <div class="grid-3">
                @foreach (var recipe in recipes)
                {
                    <partial name="_RecipeCard" model="recipe" />
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">🍽️</div>
                <h3>No recipes yet</h3>
                <p>Be the first to share a healthy recipe!</p>
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Recipe" asp-action="Create" class="btn-primary">Create recipe</a>
                }
            </div>
        }
    </div>
</section>


@section Scripts {
    <style>
    .inline-style-1 {
        background:var(--parchment);
        border-radius: 24px;
        margin: 0 24px 48px;
    }
    .inline-style-2 {
        display:flex;
        gap:48px;
        flex-wrap:wrap;
        justify-content:center;
        text-align:center;
        padding: 24px 0;
    }
    .inline-style-3 {
        font-family: var(--font-display);
        font-size:2.5rem;
        color:var(--forest);
    }
    .inline-style-4 {
        font-size:0.875rem;
        color:var(--muted);
    }
    .inline-style-5 {
        font-family: var(--font-display);
        font-size:2.5rem;
        color:var(--forest);
    }
    .inline-style-6 {
        font-size:0.875rem;
        color:var(--muted);
    }
    .inline-style-7 {
        font-family: var(--font-display);
        font-size:2.5rem;
        color:var(--forest);
    }
    .inline-style-8 {
        font-size:0.875rem;
        color:var(--muted);
    }
    .inline-style-9 {
        margin-bottom:28px;
    }
    .inline-style-10 {
        margin-bottom:0
    }
    .inline-style-11 {
        font-size:0.875rem;
    }
    </style>
}