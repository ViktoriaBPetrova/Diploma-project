@model HealthyRecipes.Web.ViewModels.MealPlanFollower.ActiveMealPlansViewModel
@using HealthyRecipes.Data.Enums
@{
    ViewData["Title"] = "My Active Meal Plans";
}

<div class="container">
    <div class="page-header">
        <h1>My Active Meal Plans</h1>
        <p class="subtitle">Track your meal plan journey</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- Active Plans -->
    @if (Model.ActivePlans.Any())
    {
        <section class="plans-section">
            <h2 class="section-title">
                <span class="status-badge status-active">Active</span>
                Currently Following (@Model.ActivePlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.ActivePlans)
                {
                    <div class="plan-card card">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(plan.MealPlanDescription))
                            {
                                <p class="description">@plan.MealPlanDescription</p>
                            }

                            <div class="plan-stats">
                                <div class="stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="stat-row">
                                    <span class="label">Duration:</span>
                                    <span class="value">@plan.DaysCount days</span>
                                </div>
                                <div class="stat-row">
                                    <span class="label">Following for:</span>
                                    <span class="value">@plan.DaysFollowing days</span>
                                </div>
                            </div>

                            <div class="macros-grid">
                                <div class="macro-pill">
                                    <span class="macro-label">Cal</span>
                                    <span class="macro-value">@Math.Round(plan.Calories / plan.DaysCount, 0)</span>
                                </div>
                                <div class="macro-pill">
                                    <span class="macro-label">P</span>
                                    <span class="macro-value">@Math.Round(plan.Protein / plan.DaysCount, 1)g</span>
                                </div>
                                <div class="macro-pill">
                                    <span class="macro-label">C</span>
                                    <span class="macro-value">@Math.Round(plan.Carbs / plan.DaysCount, 1)g</span>
                                </div>
                                <div class="macro-pill">
                                    <span class="macro-label">F</span>
                                    <span class="macro-value">@Math.Round(plan.Fat / plan.DaysCount, 1)g</span>
                                </div>
                            </div>

                            <div class="plan-actions">
                                <form asp-action="CompletePlan" asp-route-id="@plan.MealPlanId" method="post" class="inline-style-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-primary btn-sm">✓ Complete</button>
                                </form>
                                <a asp-action="PausePlan" asp-route-id="@plan.MealPlanId" class="btn-sm inline-style-2">
                                    ⏸ Pause
                                </a>
                                <a asp-action="DropPlan" asp-route-id="@plan.MealPlanId" class="btn-danger btn-sm">✕ Stop</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    else
    {
        <div class="empty-state">
            <p>You're not currently following any meal plans.</p>
            <a asp-controller="MealPlan" asp-action="Index" class="btn-primary">Browse Meal Plans</a>
        </div>
    }

    <!-- Paused Plans -->
    @if (Model.PausedPlans.Any())
    {
        <section class="plans-section">
            <h2 class="section-title">
                <span class="status-badge status-paused">Paused</span>
                Paused Plans (@Model.PausedPlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.PausedPlans)
                {
                    <div class="plan-card card paused">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            <div class="plan-stats">
                                <div class="stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="stat-row">
                                    <span class="label">Duration:</span>
                                    <span class="value">@plan.DaysCount days</span>
                                </div>
                            </div>

                            <div class="plan-actions">
                                <form asp-action="ResumePlan" asp-route-id="@plan.MealPlanId" method="post" class="inline-style-3">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-primary btn-sm">▶ Resume</button>
                                </form>
                                <a asp-action="DropPlan" asp-route-id="@plan.MealPlanId" class="btn-danger btn-sm">✕ Stop</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Completed Plans -->
    @if (Model.CompletedPlans.Any())
    {
        <section class="plans-section">
            <h2 class="section-title">
                <span class="status-badge status-completed">Completed</span>
                Completed Plans (@Model.CompletedPlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.CompletedPlans)
                {
                    <div class="plan-card card completed">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            <div class="plan-stats">
                                <div class="stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="stat-row">
                                    <span class="label">Completed:</span>
                                    <span class="value">@plan.CompletedAt?.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="stat-row">
                                    <span class="label">Duration:</span>
                                    <span class="value">@plan.DaysCount days</span>
                                </div>
                            </div>

                            <div class="completion-badge">
                                ✓ Completed
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Dropped Plans -->
    @if (Model.DroppedPlans.Any())
    {
        <section class="plans-section">
            <h2 class="section-title">
                <span class="status-badge status-dropped">Dropped</span>
                Previously Dropped (@Model.DroppedPlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.DroppedPlans)
                {
                    <div class="plan-card card dropped">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            <div class="plan-stats">
                                <div class="stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(plan.DropoutReason))
                                {
                                    <div class="stat-row">
                                        <span class="label">Reason:</span>
                                        <span class="value">@plan.DropoutReason</span>
                                    </div>
                                }
                            </div>

                            <div class="plan-actions">
                                <a asp-action="StartFollowing" asp-route-id="@plan.MealPlanId" class="btn-primary btn-sm">Start Again</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>

<style>
    .plans-section {
        margin-bottom: 48px;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        font-size: 24px;
        font-weight: 700;
        color: var(--forest);
    }

    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-active {
        background: #d4edda;
        color: #155724;
    }

    .status-paused {
        background: #fff3cd;
        color: #856404;
    }

    .status-completed {
        background: #cce5ff;
        color: #004085;
    }

    .status-dropped {
        background: #f8d7da;
        color: #721c24;
    }

    .plan-card {
        transition: transform 0.2s;
    }

    .plan-card:hover {
        transform: translateY(-2px);
    }

    .plan-card.paused {
        opacity: 0.85;
    }

    .plan-card.completed {
        border-left: 4px solid #28a745;
    }

    .plan-card.dropped {
        opacity: 0.7;
    }

    .creator-badge {
        font-size: 13px;
        color: #666;
        font-weight: 400;
    }

    .plan-stats {
        margin: 16px 0;
        padding: 12px;
        background: var(--parchment);
        border-radius: 8px;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .stat-row:last-child {
        margin-bottom: 0;
    }

    .stat-row .label {
        font-weight: 500;
        color: #666;
    }

    .stat-row .value {
        font-weight: 600;
        color: var(--forest);
    }

    .plan-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 14px;
    }

    .completion-badge {
        margin-top: 16px;
        padding: 12px;
        background: #d4edda;
        color: #155724;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        padding: 64px 24px;
        background: var(--parchment);
        border-radius: 12px;
    }

    .empty-state p {
        font-size: 18px;
        color: #666;
        margin-bottom: 24px;
    }

    .alert {
        padding: 16px;
        border-radius: 8px;
        margin-bottom: 24px;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
</style>


@section Scripts {
    <style>
    .inline-style-1 {
        display: inline;
    }
    .inline-style-2 {
        display: inline;
    }
    .inline-style-3 {
        display: inline;
    }
    </style>
}