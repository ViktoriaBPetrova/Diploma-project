@model HealthyRecipes.Web.ViewModels.MealPlanFollower.ActiveMealPlansViewModel
@using HealthyRecipes.Data.Enums
@{
    ViewData["Title"] = "My Active Meal Plans";
}

<div class="container">
    <div class="page-header">
        <h1>My Active Meal Plans</h1>
        <p class="page-subtitle">Track your meal plan journey</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">@TempData["ErrorMessage"]</div>
    }

    <!-- Active Plans -->
    @if (Model.ActivePlans.Any())
    {
        <section class="follower-plans-section">
            <h2 class="follower-section-title">
                <span class="follower-status-badge follower-status-active">Active</span>
                Currently Following (@Model.ActivePlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.ActivePlans)
                {
                    <div class="card follower-plan-card">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="follower-creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(plan.MealPlanDescription))
                            {
                                <p>@plan.MealPlanDescription</p>
                            }

                            <div class="follower-plan-stats">
                                <div class="follower-stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="follower-stat-row">
                                    <span class="label">Duration:</span>
                                    <span class="value">@plan.DaysCount days</span>
                                </div>
                                <div class="follower-stat-row">
                                    <span class="label">Following for:</span>
                                    <span class="value">@plan.DaysFollowing days</span>
                                </div>
                            </div>

                            <div class="macro-row">
                                <span class="macro-pill cal">🔥 @Math.Round(plan.Calories / plan.DaysCount, 0)</span>
                                <span class="macro-pill protein">P @Math.Round(plan.Protein / plan.DaysCount, 1)g</span>
                                <span class="macro-pill carbs">C @Math.Round(plan.Carbs / plan.DaysCount, 1)g</span>
                                <span class="macro-pill fat">F @Math.Round(plan.Fat / plan.DaysCount, 1)g</span>
                            </div>

                            <div class="follower-plan-actions">
                                <form asp-action="CompletePlan" asp-route-id="@plan.MealPlanId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-primary follower-btn-sm">✓ Complete</button>
                                </form>
                                <a asp-action="PausePlan" asp-route-id="@plan.MealPlanId" class="btn-ghost follower-btn-sm">
                                    ⏸ Pause
                                </a>
                                <a asp-action="DropPlan" asp-route-id="@plan.MealPlanId" class="btn-danger follower-btn-sm">✕ Stop</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h3>No active plans</h3>
            <p>You're not currently following any meal plans.</p>
            <a asp-controller="MealPlan" asp-action="Index" class="btn-primary">Browse Meal Plans</a>
        </div>
    }

    <!-- Paused Plans -->
    @if (Model.PausedPlans.Any())
    {
        <section class="follower-plans-section">
            <h2 class="follower-section-title">
                <span class="follower-status-badge follower-status-paused">Paused</span>
                Paused Plans (@Model.PausedPlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.PausedPlans)
                {
                    <div class="card follower-plan-card paused">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="follower-creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            <div class="follower-plan-stats">
                                <div class="follower-stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="follower-stat-row">
                                    <span class="label">Duration:</span>
                                    <span class="value">@plan.DaysCount days</span>
                                </div>
                            </div>

                            <div class="follower-plan-actions">
                                <form asp-action="ResumePlan" asp-route-id="@plan.MealPlanId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-primary follower-btn-sm">▶ Resume</button>
                                </form>
                                <a asp-action="DropPlan" asp-route-id="@plan.MealPlanId" class="btn-danger follower-btn-sm">✕ Stop</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Completed Plans -->
    @if (Model.CompletedPlans.Any())
    {
        <section class="follower-plans-section">
            <h2 class="follower-section-title">
                <span class="follower-status-badge follower-status-completed">Completed</span>
                Completed Plans (@Model.CompletedPlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.CompletedPlans)
                {
                    <div class="card follower-plan-card completed">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="follower-creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            <div class="follower-plan-stats">
                                <div class="follower-stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="follower-stat-row">
                                    <span class="label">Completed:</span>
                                    <span class="value">@plan.CompletedAt?.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="follower-stat-row">
                                    <span class="label">Duration:</span>
                                    <span class="value">@plan.DaysCount days</span>
                                </div>
                            </div>

                            <div class="follower-completion-badge">
                                ✓ Completed
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Dropped Plans -->
    @if (Model.DroppedPlans.Any())
    {
        <section class="follower-plans-section">
            <h2 class="follower-section-title">
                <span class="follower-status-badge follower-status-dropped">Dropped</span>
                Previously Dropped (@Model.DroppedPlans.Count())
            </h2>
            <div class="grid-2">
                @foreach (var plan in Model.DroppedPlans)
                {
                    <div class="card follower-plan-card dropped">
                        <div class="card-header">
                            <h3>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h3>
                            <span class="follower-creator-badge">by @plan.CreatorName</span>
                        </div>

                        <div class="card-body">
                            <div class="follower-plan-stats">
                                <div class="follower-stat-row">
                                    <span class="label">Started:</span>
                                    <span class="value">@plan.StartedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(plan.DropoutReason))
                                {
                                    <div class="follower-stat-row">
                                        <span class="label">Reason:</span>
                                        <span class="value">@plan.DropoutReason</span>
                                    </div>
                                }
                            </div>

                            <div class="follower-plan-actions">
                                <a asp-action="StartFollowing" asp-route-id="@plan.MealPlanId" class="btn-primary follower-btn-sm">Start Again</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>
