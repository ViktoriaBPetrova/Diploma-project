@model HealthyRecipes.Web.ViewModels.MealPlanFollower.PlanFollowersViewModel
@using HealthyRecipes.Data.Enums
@{
    ViewData["Title"] = $"Followers - {Model.MealPlanName}";
}

<div class="container">
    <div class="page-header">
        <h1>Meal Plan Followers</h1>
        <p class="page-subtitle">@Model.MealPlanName</p>
    </div>

    <div class="followers-stats-overview">
        <div class="followers-stat-card">
            <span class="followers-stat-number">@Model.TotalFollowers</span>
            <span class="followers-stat-label">Total Followers</span>
        </div>
        <div class="followers-stat-card">
            <span class="followers-stat-number">@Model.ActiveFollowers</span>
            <span class="followers-stat-label">Active</span>
        </div>
        <div class="followers-stat-card">
            <span class="followers-stat-number">@Model.CompletedFollowers</span>
            <span class="followers-stat-label">Completed</span>
        </div>
        <div class="followers-stat-card">
            <span class="followers-stat-number">@(Model.CompletedFollowers > 0 ? Math.Round((double)Model.CompletedFollowers / Model.TotalFollowers * 100, 1) : 0)%</span>
            <span class="followers-stat-label">Completion Rate</span>
        </div>
    </div>

    @if (Model.Followers.Any())
    {
        <div class="followers-list">
            @foreach (var follower in Model.Followers)
            {
                <div class="card followers-follower-card">
                    <div class="followers-info">
                        <div class="followers-avatar">
                            @follower.UserName.Substring(0, 1).ToUpper()
                        </div>
                        <div class="followers-details">
                            <h3>@follower.UserName</h3>
                            @if (!string.IsNullOrEmpty(follower.UserEmail))
                            {
                                <p class="followers-email">@follower.UserEmail</p>
                            }
                        </div>
                    </div>

                    <div class="followers-stats">
                        <div class="stat-item">
                            <span class="label">Status</span>
                            <span class="followers-badge followers-badge-@follower.Status.ToString().ToLower()">
                                @follower.Status.ToString()
                            </span>
                        </div>
                        <div class="stat-item">
                            <span class="label">Started</span>
                            <span class="value">@follower.StartedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        @if (follower.CompletedAt.HasValue)
                        {
                            <div class="stat-item">
                                <span class="label">Completed</span>
                                <span class="value">@follower.CompletedAt.Value.ToString("MMM dd, yyyy")</span>
                            </div>
                        }
                        else
                        {
                            <div class="stat-item">
                                <span class="label">Following for</span>
                                <span class="value">@follower.DaysFollowing days</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">👥</div>
            <h3>No followers yet</h3>
            <p>No one is following this meal plan yet.</p>
            <p class="page-subtitle">Be the first to start!</p>
        </div>
    }

    <div class="followers-actions">
        <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.MealPlanId" class="btn-ghost">Back to Meal Plan</a>
    </div>
</div>
