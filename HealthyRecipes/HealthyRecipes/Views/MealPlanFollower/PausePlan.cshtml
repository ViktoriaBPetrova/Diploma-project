@model HealthyRecipes.Web.ViewModels.MealPlanFollower.ReasonMealPlanViewModel
@{
    ViewData["Title"] = "Pause Meal Plan";
}

<div class="container">
    <div class="page-header">
        <h1>Pause Meal Plan</h1>
        <p class="subtitle">Tell us why you're pausing</p>
    </div>

    <div class="card inline-style-1">
        <div class="card-header">
            <h2>@Model.MealPlanName</h2>
        </div>

        <div class="card-body">
            <form asp-action="PausePlan" asp-route-id="@Model.MealPlanId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MealPlanId" />
                <input type="hidden" asp-for="MealPlanName" />

                <div class="form-group">
                    <label asp-for="Reason">Reason (Optional)</label>
                    <textarea asp-for="Reason" 
                              class="form-control" 
                              rows="4" 
                              placeholder="Let us know why you're pausing this meal plan..."></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                    <small>This helps us improve meal plan recommendations</small>
                </div>

                <div class="warning-box inline-style-2">
                    <strong>⚠️ Are you sure?</strong>
                    <p class="inline-style-3">
                        You can always resume this meal plan later and your current progress will be saved.
                    </p>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-danger inline-style-4">
                        Pause for some time
                    </button>
                    <a asp-action="MyActivePlans" class="btn-ghost inline-style-5">
                        Keep actively Following
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
    .inline-style-1 {
        max-width: 600px;
        margin: 0 auto;
    }
    .inline-style-2 {
        margin: 24px 0;
        padding: 16px;
        background: #fff3cd;
        border-left: 4px solid #ffc107;
    }
    .inline-style-3 {
        margin: 8px 0 0 0;
    }
    .inline-style-4 {
        width: 100%;
    }
    .inline-style-5 {
        width: 100%;
        text-align: center;
        margin-top: 12px;
    }
    </style>
}
