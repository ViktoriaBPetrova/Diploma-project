@model HealthyRecipes.Web.ViewModels.MealPlanFollower.FollowingDashboard.FollowingDashboardViewModel
@{
    ViewData["Title"] = "My Following";
}

<div class="container">
    @if (Model.ActivePlan != null && Model.TodaysSchedule != null)
    {
        <!-- Completion Alert -->
        @if (Model.ShowCompletionAlert)
        {
            <div class="follower-completion-alert">
                <div class="alert-content">
                    <strong>🎉 Time to Complete!</strong>
                    <p>@Model.CompletionAlertMessage</p>
                </div>
                <div class="alert-actions">
                    <form asp-action="CompletePlan" asp-route-id="@Model.ActivePlan.MealPlanId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary">✓ Mark Complete</button>
                    </form>
                    <form asp-action="DismissCompletionAlert" asp-route-id="@Model.ActivePlan.MealPlanId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-ghost">Dismiss</button>
                    </form>
                </div>
            </div>
        }

        <!-- Two-Column Layout -->
        <div class="follower-dashboard-layout">
            
            <!-- MAIN CONTENT (Left Column) -->
            <div class="follower-main-content">
                
                <!-- Plan Header -->
                <div class="card plan-header-card">
                    <div class="card-body">
                        <div class="plan-header-top">
                            <div>
                                <span class="follower-status-badge follower-status-active">Active</span>
                                <h1 class="plan-header-title">@Model.ActivePlan.Name</h1>
                                @if (!string.IsNullOrEmpty(Model.ActivePlan.Description))
                                {
                                    <p class="plan-header-description">@Model.ActivePlan.Description</p>
                                }
                                <p class="plan-header-creator">by <strong>@Model.ActivePlan.CreatorName</strong></p>
                            </div>
                            <div class="plan-header-actions">
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.ActivePlan.MealPlanId" class="btn-ghost">View Full Plan</a>
                                <a asp-action="PausePlan" asp-route-id="@Model.ActivePlan.MealPlanId" class="btn-ghost">⏸️ Pause</a>
                                <a asp-action="DropPlan" asp-route-id="@Model.ActivePlan.MealPlanId" class="btn-danger">Drop Plan</a>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        <div class="plan-progress-section">
                            <div class="progress-stats-row">
                                <div class="progress-stat">
                                    <span class="stat-label">Day</span>
                                    <span class="stat-value">@Model.ActivePlan.DaysFollowing of @Model.ActivePlan.TotalDays</span>
                                </div>
                                <div class="progress-stat">
                                    <span class="stat-label">Remaining</span>
                                    <span class="stat-value">@Model.ActivePlan.DaysRemaining days</span>
                                </div>
                                <div class="progress-stat">
                                    <span class="stat-label">Expected Completion</span>
                                    <span class="stat-value">@Model.ActivePlan.ExpectedCompletionDate.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-bar" style="width: @Model.ActivePlan.ProgressPercentage%"></div>
                            </div>
                            <p class="progress-percentage">@Model.ActivePlan.ProgressPercentage.ToString("F1")% Complete</p>
                        </div>
                    </div>
                </div>

                <!-- All Days History -->
                <div class="days-history-section">
                    <h2 class="section-title">Your Journey</h2>
                    
                    <div class="days-timeline">
                        @foreach (var day in Model.PastDays)
                        {
                            <div class="day-timeline-item @(day.IsToday ? "is-today" : "") @(day.IsFuture ? "is-future" : "") @(day.LoggedMeals == day.TotalMeals && day.HasDayReflection ? "is-complete" : "")">
                                <div class="day-timeline-marker">
                                    @if (day.LoggedMeals == day.TotalMeals && day.HasDayReflection)
                                    {
                                        <span class="day-marker-icon complete">✓</span>
                                    }
                                    else if (day.IsToday)
                                    {
                                        <span class="day-marker-icon today">●</span>
                                    }
                                    else if (day.IsFuture)
                                    {
                                        <span class="day-marker-icon future">○</span>
                                    }
                                    else
                                    {
                                        <span class="day-marker-icon partial">◐</span>
                                    }
                                </div>
                                
                                <div class="day-timeline-content card">
                                    <div class="card-body">
                                        <div class="day-header-row">
                                            <div>
                                                <h3 class="day-title">
                                                    Day @day.DayNumber - @day.DayOfWeek
                                                    @if (day.IsToday)
                                                    {
                                                        <span class="day-badge today-badge">Today</span>
                                                    }
                                                    @if (day.IsFuture)
                                                    {
                                                        <span class="day-badge future-badge">Upcoming</span>
                                                    }
                                                </h3>
                                                <p class="day-date">@day.Date.ToString("MMM dd, yyyy")</p>
                                            </div>
                                            <div class="day-completion-circle">
                                                <span class="completion-percentage">@day.CompletionPercentage%</span>
                                            </div>
                                        </div>

                                        <div class="day-stats-row">
                                            <div class="day-stat">
                                                <span class="stat-icon">🍽️</span>
                                                <span>@day.LoggedMeals/@day.TotalMeals meals logged</span>
                                            </div>
                                            @if (day.HasDayReflection)
                                            {
                                                <div class="day-stat">
                                                    <span class="stat-icon">📝</span>
                                                    <span>Reflection added</span>
                                                </div>
                                            }
                                        </div>

                                        @if (!string.IsNullOrEmpty(day.DayReflection) && !day.IsFuture)
                                        {
                                            <div class="day-reflection-box">
                                                <p class="reflection-text">"@day.DayReflection"</p>
                                            </div>
                                        }

                                        <div class="macro-row">
                                            <span class="macro-pill cal">🔥 @day.Calories.ToString("F0")</span>
                                            <span class="macro-pill protein">P @day.Protein.ToString("F0")g</span>
                                            <span class="macro-pill carbs">C @day.Carbs.ToString("F0")g</span>
                                            <span class="macro-pill fat">F @day.Fat.ToString("F0")g</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- SIDEBAR (Right Column - Today's Meals) -->
            <aside class="follower-sidebar">
                <div class="sidebar-sticky">
                    <div class="card sidebar-today-card">
                        <div class="card-body">
                            <h2 class="sidebar-title">📅 Today - Day @Model.TodaysSchedule.CurrentDayNumber</h2>
                            <p class="sidebar-subtitle">@Model.TodaysSchedule.DayOfWeek</p>

                            <!-- Today's Meals -->
                            <div class="sidebar-meals">
                                @foreach (var meal in Model.TodaysSchedule.Meals)
                                {
                                    <div class="sidebar-meal-item">
                                        <h4 class="sidebar-meal-type">@meal.Type</h4>
                                        
                                        <div class="sidebar-meal-recipes">
                                            @foreach (var recipe in meal.Recipes)
                                            {
                                                <div class="sidebar-recipe">
                                                    @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                                                    {
                                                        <img src="@recipe.ImageUrl" alt="@recipe.Name" class="sidebar-recipe-thumb" />
                                                    }
                                                    <div class="sidebar-recipe-info">
                                                        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.RecipeId" class="sidebar-recipe-name">@recipe.Name</a>
                                                        @if (recipe.PrepTime.HasValue)
                                                        {
                                                            <span class="sidebar-recipe-time">⏱️ @recipe.PrepTime min</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        @if (meal.HasEntry)
                                        {
                                            <div class="sidebar-meal-logged">
                                                <span class="logged-icon">✓</span>
                                                <span>Logged @meal.ConsumedAt?.ToString("h:mm tt")</span>
                                            </div>
                                            <a asp-action="LogMeal" asp-route-mealId="@meal.MealId" class="btn-ghost btn-sidebar-sm">✏️ Edit</a>
                                        }
                                        else
                                        {
                                            <a asp-action="LogMeal" asp-route-mealId="@meal.MealId" class="btn-primary btn-sidebar-full">📷 Log Meal</a>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Day Totals -->
                            <div class="sidebar-totals">
                                <h4>Daily Totals</h4>
                                <div class="macro-row">
                                    <span class="macro-pill cal">🔥 @Model.TodaysSchedule.Calories.ToString("F0")</span>
                                    <span class="macro-pill protein">P @Model.TodaysSchedule.Protein.ToString("F0")g</span>
                                    <span class="macro-pill carbs">C @Model.TodaysSchedule.Carbs.ToString("F0")g</span>
                                    <span class="macro-pill fat">F @Model.TodaysSchedule.Fat.ToString("F0")g</span>
                                </div>
                            </div>

                            <!-- Day Reflection -->
                            <div class="sidebar-reflection">
                                @if (Model.TodaysSchedule.HasDayEntry)
                                {
                                    <p class="sidebar-reflection-text">"@Model.TodaysSchedule.DayOverallFeeling"</p>
                                    <a asp-action="LogDayReflection" asp-route-dayId="@Model.TodaysSchedule.MealPlanDayId" class="btn-ghost btn-sidebar-sm">✏️ Edit Reflection</a>
                                }
                                else
                                {
                                    <p class="sidebar-reflection-prompt">How was your day?</p>
                                    <a asp-action="LogDayReflection" asp-route-dayId="@Model.TodaysSchedule.MealPlanDayId" class="btn-primary btn-sidebar-full">📝 Add Reflection</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h3>No active plan</h3>
            <p>You're not currently following any meal plan. Browse our collection to find your perfect plan!</p>
            <a asp-controller="MealPlan" asp-action="Index" class="btn-primary">Browse Meal Plans</a>
        </div>
    }

    <!-- Paused Plans Section (if any) -->
    @if (Model.PausedPlans.Any())
    {
        <div class="follower-paused-section">
            <div class="section-header">
                <h3 class="section-title">
                    <span class="follower-status-badge follower-status-paused">Paused</span>
                    Paused Plans (@Model.PausedPlans.Count())
                </h3>
                <p class="section-subtitle">Resume when you're ready to continue</p>
            </div>

            <div class="paused-plans-grid">
                @foreach (var plan in Model.PausedPlans)
                {
                    <div class="card paused-plan-card">
                        <div class="card-body">
                            <h4 class="paused-plan-title">
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId">@plan.MealPlanName</a>
                            </h4>
                            <span class="plan-card-creator">by @plan.CreatorName</span>

                            @if (!string.IsNullOrEmpty(plan.MealPlanDescription))
                            {
                                <p class="paused-plan-description">@plan.MealPlanDescription</p>
                            }

                            <div class="paused-plan-meta">
                                <div class="meta-row">
                                    <span class="meta-label">Duration:</span>
                                    <span class="meta-value">@plan.DaysCount days</span>
                                </div>
                                <div class="meta-row">
                                    <span class="meta-label">Paused:</span>
                                    <span class="meta-value">@plan.PausedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(plan.PauseReason))
                            {
                                <div class="pause-reason-box">
                                    <strong>Reason:</strong> "@plan.PauseReason"
                                </div>
                            }

                            <div class="macro-row">
                                <span class="macro-pill cal">🔥 @plan.Calories.ToString("F0")</span>
                                <span class="macro-pill protein">P @plan.Protein.ToString("F0")g</span>
                                <span class="macro-pill carbs">C @plan.Carbs.ToString("F0")g</span>
                                <span class="macro-pill fat">F @plan.Fat.ToString("F0")g</span>
                            </div>

                            <div class="paused-plan-actions">
                                <form asp-action="ResumePlan" asp-route-id="@plan.MealPlanId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-primary btn-action-full">▶️ Resume Plan</button>
                                </form>
                                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@plan.MealPlanId" class="btn-ghost btn-action-full">View Details</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Quick Links -->
    <div class="follower-quick-links">
        <a asp-action="MyActivePlans" class="quick-link">View All My Plans (Active/Completed/Dropped)</a>
        <a asp-controller="MealPlan" asp-action="Index" class="quick-link">Browse More Meal Plans</a>
    </div>
</div>
