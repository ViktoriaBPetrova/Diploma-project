@model HealthyRecipes.Web.ViewModels.MealPlanFollower.StartFollowingViewModel
@{
    ViewData["Title"] = "Start Following Meal Plan";
}

<div class="container">
    <div class="page-header">
        <h1>Start Following Meal Plan</h1>
        <p class="subtitle">Begin tracking your progress with this meal plan</p>
    </div>

    <div class="card inline-style-1">
        <div class="card-header">
            <h2>@Model.MealPlanName</h2>
        </div>

        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.MealPlanDescription))
            {
                <p class="description">@Model.MealPlanDescription</p>
            }

            <div class="nutrition-summary inline-style-2">
                <div class="stat-grid">
                    <div class="stat-item">
                        <span class="stat-label">Duration</span>
                        <span class="stat-value">@Model.DaysCount days</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Daily Calories</span>
                        <span class="stat-value">@Math.Round(Model.Calories / Model.DaysCount, 0) kcal</span>
                    </div>
                </div>

                <div class="macros-grid inline-style-3">
                    <div class="macro-pill">
                        <span class="macro-label">Protein</span>
                        <span class="macro-value">@Math.Round(Model.Protein / Model.DaysCount, 1)g</span>
                    </div>
                    <div class="macro-pill">
                        <span class="macro-label">Carbs</span>
                        <span class="macro-value">@Math.Round(Model.Carbs / Model.DaysCount, 1)g</span>
                    </div>
                    <div class="macro-pill">
                        <span class="macro-label">Fat</span>
                        <span class="macro-value">@Math.Round(Model.Fat / Model.DaysCount, 1)g</span>
                    </div>
                </div>
            </div>

            <div class="info-box inline-style-4">
                <h4 class="inline-style-5">What happens when you follow a meal plan?</h4>
                <ul class="inline-style-6">
                    <li>Track your daily progress through the plan</li>
                    <li>Get nutrition insights and meal reminders</li>
                    <li>Mark the plan as completed when done</li>
                    <li>View your meal plan history</li>
                </ul>
            </div>

            <form asp-action="StartFollowing" asp-route-id="@Model.MealPlanId" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-actions inline-style-7">
                    <button type="submit" class="btn-primary inline-style-8">
                        Start Following This Plan
                    </button>
                    <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.MealPlanId" class="btn-ghost inline-style-9">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .stat-label {
        font-size: 14px;
        color: #666;
        font-weight: 500;
    }

    .stat-value {
        font-size: 20px;
        font-weight: 700;
        color: var(--forest);
    }

    .macros-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .info-box ul {
        padding-left: 20px;
    }

    .info-box li {
        margin-bottom: 8px;
    }
</style>


@section Scripts {
    <style>
    .inline-style-1 {
        max-width: 800px;
        margin: 0 auto;
    }
    .inline-style-2 {
        margin: 24px 0;
    }
    .inline-style-3 {
        margin-top: 16px;
    }
    .inline-style-4 {
        margin: 24px 0;
        padding: 16px;
        background: var(--parchment);
        border-left: 4px solid var(--forest);
    }
    .inline-style-5 {
        margin-top: 0;
    }
    .inline-style-6 {
        margin-bottom: 0;
    }
    .inline-style-7 {
        margin-top: 24px;
    }
    .inline-style-8 {
        width: 100%;
    }
    .inline-style-9 {
        width: 100%;
        text-align: center;
        margin-top: 12px;
    }
    </style>
}