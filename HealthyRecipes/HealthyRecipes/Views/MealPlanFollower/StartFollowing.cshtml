@model HealthyRecipes.Web.ViewModels.MealPlanFollower.StartFollowingViewModel
@{
    ViewData["Title"] = "Start Following Meal Plan";
}

<div class="container">
    <div class="page-header">
        <h1>Start Following Meal Plan</h1>
        <p class="page-subtitle">Begin tracking your progress with this meal plan</p>
    </div>

    <div class="card follower-card-wide">
        <div class="card-header">
            <h2>@Model.MealPlanName</h2>
        </div>

        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.MealPlanDescription))
            {
                <p>@Model.MealPlanDescription</p>
            }

            <div class="follower-nutrition-summary">
                <div class="follower-stat-grid">
                    <div class="follower-stat-item">
                        <span class="follower-stat-label">Duration</span>
                        <span class="follower-stat-value">@Model.DaysCount days</span>
                    </div>
                    <div class="follower-stat-item">
                        <span class="follower-stat-label">Daily Calories</span>
                        <span class="follower-stat-value">@Math.Round(Model.Calories / Model.DaysCount, 0) kcal</span>
                    </div>
                </div>

                <div class="follower-macros-grid">
                    <div class="macro-pill">
                        <span>Protein: @Math.Round(Model.Protein / Model.DaysCount, 1)g</span>
                    </div>
                    <div class="macro-pill">
                        <span>Carbs: @Math.Round(Model.Carbs / Model.DaysCount, 1)g</span>
                    </div>
                    <div class="macro-pill">
                        <span>Fat: @Math.Round(Model.Fat / Model.DaysCount, 1)g</span>
                    </div>
                </div>
            </div>

            <div class="follower-info-box">
                <h4>What happens when you follow a meal plan?</h4>
                <ul>
                    <li>Track your daily progress through the plan</li>
                    <li>Get nutrition insights and meal reminders</li>
                    <li>Mark the plan as completed when done</li>
                    <li>View your meal plan history</li>
                </ul>
            </div>

            <form asp-action="StartFollowing" asp-route-id="@Model.MealPlanId" method="post">
                @Html.AntiForgeryToken()
                
                <div class="follower-form-actions">
                    <button type="submit" class="btn-primary follower-btn-full">
                        Start Following This Plan
                    </button>
                    <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.MealPlanId" class="btn-ghost follower-btn-full-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
