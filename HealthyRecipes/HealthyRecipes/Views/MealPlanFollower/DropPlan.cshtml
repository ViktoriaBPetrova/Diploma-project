@model HealthyRecipes.Web.ViewModels.MealPlanFollower.ReasonMealPlanViewModel
@{
    ViewData["Title"] = "Stop Following Meal Plan";
}

<div class="container">
    <div class="page-header">
        <h1>Stop Following Meal Plan</h1>
        <p class="page-subtitle">Tell us why you're stopping</p>
    </div>

    <div class="card follower-card-centered">
        <div class="card-header">
            <h2>@Model.MealPlanName</h2>
        </div>

        <div class="card-body">
            <form asp-action="DropPlan" asp-route-id="@Model.MealPlanId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MealPlanId" />
                <input type="hidden" asp-for="MealPlanName" />

                <div class="form-group">
                    <label asp-for="Reason">Reason (Optional)</label>
                    <textarea asp-for="Reason" 
                              class="form-control" 
                              rows="4" 
                              placeholder="Let us know why you're stopping this meal plan..."></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                    <small class="form-hint">This helps us improve meal plan recommendations</small>
                </div>

                <div class="follower-warning-box">
                    <strong>⚠️ Are you sure?</strong>
                    <p class="follower-warning-text">
                        You can always resume this meal plan later, but your current progress will not be saved.
                    </p>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-danger follower-btn-full">
                        Stop Following
                    </button>
                    <a asp-action="MyActivePlans" class="btn-ghost follower-btn-full-secondary">
                        Keep Following
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
