@model HealthyRecipes.Web.ViewModels.Category.CreateCategoryViewModel
@{ ViewData["Title"] = "New Category"; }

<div class="container inline-style-1">
    <div class="inline-style-2">
        <a asp-action="Index" class="inline-style-3">← Categories</a>
        <h1 class="inline-style-4">New Category</h1>

        <div class="form-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Name">Category name *</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Vegan, Keto, High Protein" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="inline-style-5">
                    <button type="submit" class="btn-primary">Create</button>
                    <a asp-action="Index" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <style>
    .inline-style-1 {
        padding-top:48px;
        padding-bottom:64px;
    }
    .inline-style-2 {
        max-width:480px;
        margin:0 auto;
    }
    .inline-style-3 {
        color:var(--muted);
        font-size:0.875rem;
    }
    .inline-style-4 {
        margin:16px 0 8px;
    }
    .inline-style-5 {
        display:flex;
        gap:12px;
    }
    </style>
}