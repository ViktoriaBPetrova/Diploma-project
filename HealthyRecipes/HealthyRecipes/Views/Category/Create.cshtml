@model HealthyRecipes.Web.Models.Category.CreateCategoryViewModel
@{ ViewData["Title"] = "New Category"; }

<div class="container" style="padding-top:48px; padding-bottom:64px;">
    <div style="max-width:480px; margin:0 auto;">
        <a asp-action="Index" style="color:var(--muted); font-size:0.875rem;">← Categories</a>
        <h1 style="margin:16px 0 8px;">New Category</h1>

        <div class="form-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Name">Category name *</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Vegan, Keto, High Protein" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn-primary">Create</button>
                    <a asp-action="Index" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
