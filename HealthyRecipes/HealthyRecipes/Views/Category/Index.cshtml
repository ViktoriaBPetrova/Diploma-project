@model HealthyRecipes.Web.ViewModels.Category.CategoryIndexViewModel
@{ ViewData["Title"] = "Categories"; }

<div class="container">
    <div class="page-header">
        <div class="page-header-row">
            <div>
                <h1>Categories</h1>
                <p class="page-subtitle">Organise recipes by type</p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn-primary">+ New Category</a>
            }
        </div>
    </div>

    @if (Model.Categories.Any())
    {
        <div class="grid-3">
            @foreach (var cat in Model.Categories)
            {
                <div class="card category-card">
                    <h3 class="category-card-title">@cat.Name</h3>
                    <p class="category-recipe-count">@cat.RecipeCount recipes</p>
                    <a asp-controller="Recipe" asp-action="Index" asp-route-categoryId="@cat.Id" class="btn-ghost category-browse-btn">Browse →</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('Delete category?')" class="category-delete-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-danger category-delete-btn">Delete</button>
                        </form>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">🗂️</div>
            <h3>No categories yet</h3>
        </div>
    }
</div>

