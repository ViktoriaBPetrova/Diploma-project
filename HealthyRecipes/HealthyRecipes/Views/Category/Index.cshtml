@model HealthyRecipes.Web.ViewModels.Category.CategoryIndexViewModel
@{ ViewData["Title"] = "Categories"; }

<div class="container">
    <div class="page-header">
        <div class="page-header-row">
            <div>
                <h1>Categories</h1>
                <p class="page-subtitle">Organise recipes by type</p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn-primary">+ New Category</a>
            }
        </div>
    </div>

    @if (Model.Categories.Any())
    {
        <div class="grid-3">
            @foreach (var cat in Model.Categories)
            {
                <div class="card inline-style-1">
                    <h3 class="inline-style-2">@cat.Name</h3>
                    <p class="inline-style-3">@cat.RecipeCount recipes</p>
                    <a asp-controller="Recipe" asp-action="Index" asp-route-categoryId="@cat.Id" class="btn-ghost inline-style-4">Browse →</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('Delete category?')" class="inline-style-5">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-danger inline-style-6">Delete</button>
                        </form>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">🗂️</div>
            <h3>No categories yet</h3>
        </div>
    }
</div>


@section Scripts {
    <style>
    .inline-style-1 {
        padding:24px;
        text-align:center;
    }
    .inline-style-2 {
        margin-bottom:6px;
    }
    .inline-style-3 {
        color:var(--muted);
        margin-bottom:16px;
    }
    .inline-style-4 {
        font-size:0.875rem;
    }
    .inline-style-5 {
        display:inline;
        margin-left:8px;
    }
    .inline-style-6 {
        font-size:0.78rem;
        padding:6px 12px;
    }
    </style>
}