@model HealthyRecipes.Web.ViewModels.Statistics.MealPlanStatisticsViewModel

@if (Model != null)
{
    <div class="stats-partial-card">
        <h5 class="stats-partial-title">📊 Meal Plan Statistics</h5>
        
        <div class="stats-partial-grid">
            <!-- Save Count -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-success">@Model.SaveCount</div>
                <small class="stats-partial-label">Saves</small>
            </div>

            <!-- Active Followers -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-primary">@Model.ActiveFollowerCount</div>
                <small class="stats-partial-label">Active Followers</small>
            </div>

            <!-- Completion Rate -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-info">@Model.CompletionRateDisplay</div>
                <small class="stats-partial-label">Completion Rate</small>
            </div>
        </div>

        <div class="stats-partial-footer">
            <span class="stats-partial-badge">@Model.PopularityLevel</span>
        </div>
    </div>
}
else
{
    <div class="stats-partial-card">
        <p class="stats-partial-unavailable">Statistics unavailable</p>
    </div>
}
