@model HealthyRecipes.Web.ViewModels.Statistics.UserStatisticsViewModel
@{
    ViewData["Title"] = "My Statistics Dashboard";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4">📊 Your Statistics</h1>
            <p class="text-muted">Track your content performance and engagement</p>
        </div>
    </div>

    <!-- Overview Cards -->
    <div class="row g-4 mb-4">
        <!-- Content Created -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Content Created</h6>
                            <h2 class="mb-0">@Model.TotalContentCreated</h2>
                        </div>
                        <span class="badge bg-primary rounded-circle p-3">📝</span>
                    </div>
                    <small class="text-muted">
                        @Model.RecipesCreatedCount recipes, @Model.MealPlansCreatedCount meal plans
                    </small>
                </div>
            </div>
        </div>

        <!-- Total Saves -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Total Saves</h6>
                            <h2 class="mb-0">@(Model.TotalRecipeSaves + Model.TotalMealPlanSaves)</h2>
                        </div>
                        <span class="badge bg-success rounded-circle p-3">❤️</span>
                    </div>
                    <small class="text-muted">
                        @Model.TotalRecipeSaves recipes, @Model.TotalMealPlanSaves meal plans
                    </small>
                </div>
            </div>
        </div>

        <!-- Average Rating -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Average Rating</h6>
                            <h2 class="mb-0">@Model.AverageRatingDisplay</h2>
                        </div>
                        <span class="badge bg-warning rounded-circle p-3">⭐</span>
                    </div>
                    <small class="text-muted">Across all recipes</small>
                </div>
            </div>
        </div>

        <!-- Comments Received -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Comments</h6>
                            <h2 class="mb-0">@Model.TotalCommentsReceived</h2>
                        </div>
                        <span class="badge bg-info rounded-circle p-3">💬</span>
                    </div>
                    <small class="text-muted">Total feedback received</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Breakdown -->
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-4">📚 Content Breakdown</h5>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <span class="me-2">🍳</span>
                                <div>
                                    <div class="fw-bold">@Model.RecipesCreatedCount</div>
                                    <small class="text-muted">Recipes</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <span class="me-2">📅</span>
                                <div>
                                    <div class="fw-bold">@Model.MealPlansCreatedCount</div>
                                    <small class="text-muted">Meal Plans</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <span class="me-2">🥕</span>
                                <div>
                                    <div class="fw-bold">@Model.IngredientsCreatedCount</div>
                                    <small class="text-muted">Ingredients</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <span class="me-2">🏷️</span>
                                <div>
                                    <div class="fw-bold">@Model.CategoriesCreatedCount</div>
                                    <small class="text-muted">Categories</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-4">🎯 Engagement Stats</h5>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Recipe Saves</span>
                            <span class="fw-bold">@Model.TotalRecipeSaves</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar" 
                                 style="width: @(Model.TotalEngagement > 0 ? (Model.TotalRecipeSaves * 100.0 / Model.TotalEngagement) : 0)%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Meal Plan Saves</span>
                            <span class="fw-bold">@Model.TotalMealPlanSaves</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-primary" role="progressbar" 
                                 style="width: @(Model.TotalEngagement > 0 ? (Model.TotalMealPlanSaves * 100.0 / Model.TotalEngagement) : 0)%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between mb-1">
                            <span>Comments Received</span>
                            <span class="fw-bold">@Model.TotalCommentsReceived</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-info" role="progressbar" 
                                 style="width: @(Model.TotalEngagement > 0 ? (Model.TotalCommentsReceived * 100.0 / Model.TotalEngagement) : 0)%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Most Popular Content -->
    <div class="row g-4">
        @if (Model.HasMostPopularRecipe)
        {
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-4">🏆 Most Popular Recipe</h5>
                        <h6 class="mb-2">@Model.MostPopularRecipeTitle</h6>
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-success me-2">❤️ @Model.MostPopularRecipeSaveCount saves</span>
                        </div>
                        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@Model.MostPopularRecipeId" 
                           class="btn btn-sm btn-outline-primary">View Recipe</a>
                    </div>
                </div>
            </div>
        }

        @if (Model.HasMostPopularMealPlan)
        {
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-4">🏆 Most Popular Meal Plan</h5>
                        <h6 class="mb-2">@Model.MostPopularMealPlanName</h6>
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-success me-2">❤️ @Model.MostPopularMealPlanSaveCount saves</span>
                        </div>
                        <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.MostPopularMealPlanId" 
                           class="btn btn-sm btn-outline-primary">View Meal Plan</a>
                    </div>
                </div>
            </div>
        }

        @if (!Model.HasMostPopularRecipe && !Model.HasMostPopularMealPlan)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5">
                        <h5 class="text-muted">No content created yet</h5>
                        <p class="text-muted mb-4">Start creating recipes and meal plans to see your statistics!</p>
                        <a asp-controller="Recipe" asp-action="Create" class="btn btn-primary me-2">Create Recipe</a>
                        <a asp-controller="MealPlan" asp-action="Create" class="btn btn-outline-primary">Create Meal Plan</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
