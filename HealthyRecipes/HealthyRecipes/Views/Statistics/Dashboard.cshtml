@model HealthyRecipes.Web.ViewModels.Statistics.UserStatisticsViewModel
@{
    ViewData["Title"] = "My Statistics Dashboard";
}

<div class="container dashboard-container">
    <div class="dashboard-header">
        <h1 class="dashboard-title">📊 Your Statistics</h1>
        <p class="dashboard-subtitle">Track your content performance and engagement</p>
    </div>

    <!-- Overview Cards -->
    <div class="dashboard-overview-grid">
        <!-- Content Created -->
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-header">
                <div>
                    <h6 class="dashboard-stat-label">Content Created</h6>
                    <h2 class="dashboard-stat-value">@Model.TotalContentCreated</h2>
                </div>
                <span class="dashboard-stat-icon dashboard-stat-icon-primary">📝</span>
            </div>
            <small class="dashboard-stat-detail">
                @Model.RecipesCreatedCount recipes, @Model.MealPlansCreatedCount meal plans
            </small>
        </div>

        <!-- Total Saves -->
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-header">
                <div>
                    <h6 class="dashboard-stat-label">Total Saves</h6>
                    <h2 class="dashboard-stat-value">@(Model.TotalRecipeSaves + Model.TotalMealPlanSaves)</h2>
                </div>
                <span class="dashboard-stat-icon dashboard-stat-icon-success">❤️</span>
            </div>
            <small class="dashboard-stat-detail">
                @Model.TotalRecipeSaves recipes, @Model.TotalMealPlanSaves meal plans
            </small>
        </div>

        <!-- Average Rating -->
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-header">
                <div>
                    <h6 class="dashboard-stat-label">Average Rating</h6>
                    <h2 class="dashboard-stat-value">@Model.AverageRatingDisplay</h2>
                </div>
                <span class="dashboard-stat-icon dashboard-stat-icon-warning">⭐</span>
            </div>
            <small class="dashboard-stat-detail">Across all recipes</small>
        </div>

        <!-- Comments Received -->
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-header">
                <div>
                    <h6 class="dashboard-stat-label">Comments</h6>
                    <h2 class="dashboard-stat-value">@Model.TotalCommentsReceived</h2>
                </div>
                <span class="dashboard-stat-icon dashboard-stat-icon-info">💬</span>
            </div>
            <small class="dashboard-stat-detail">Total feedback received</small>
        </div>
    </div>

    <!-- Content Breakdown & Engagement -->
    <div class="dashboard-content-grid">
        <div class="dashboard-section-card">
            <h5 class="dashboard-section-title">📚 Content Breakdown</h5>
            <div class="dashboard-breakdown-grid">
                <div class="dashboard-breakdown-item">
                    <span class="dashboard-breakdown-icon">🍳</span>
                    <div>
                        <div class="dashboard-breakdown-value">@Model.RecipesCreatedCount</div>
                        <small class="dashboard-breakdown-label">Recipes</small>
                    </div>
                </div>
                <div class="dashboard-breakdown-item">
                    <span class="dashboard-breakdown-icon">📅</span>
                    <div>
                        <div class="dashboard-breakdown-value">@Model.MealPlansCreatedCount</div>
                        <small class="dashboard-breakdown-label">Meal Plans</small>
                    </div>
                </div>
                <div class="dashboard-breakdown-item">
                    <span class="dashboard-breakdown-icon">🥕</span>
                    <div>
                        <div class="dashboard-breakdown-value">@Model.IngredientsCreatedCount</div>
                        <small class="dashboard-breakdown-label">Ingredients</small>
                    </div>
                </div>
                <div class="dashboard-breakdown-item">
                    <span class="dashboard-breakdown-icon">🏷️</span>
                    <div>
                        <div class="dashboard-breakdown-value">@Model.CategoriesCreatedCount</div>
                        <small class="dashboard-breakdown-label">Categories</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-section-card">
            <h5 class="dashboard-section-title">🎯 Engagement Stats</h5>
            <div class="dashboard-progress-item">
                <div class="dashboard-progress-header">
                    <span>Recipe Saves</span>
                    <span class="dashboard-breakdown-value">@Model.TotalRecipeSaves</span>
                </div>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill dashboard-progress-fill-success" 
                         style="width: @(Model.TotalEngagement > 0 ? (Model.TotalRecipeSaves * 100.0 / Model.TotalEngagement) : 0)%"></div>
                </div>
            </div>
            <div class="dashboard-progress-item">
                <div class="dashboard-progress-header">
                    <span>Meal Plan Saves</span>
                    <span class="dashboard-breakdown-value">@Model.TotalMealPlanSaves</span>
                </div>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill dashboard-progress-fill-primary" 
                         style="width: @(Model.TotalEngagement > 0 ? (Model.TotalMealPlanSaves * 100.0 / Model.TotalEngagement) : 0)%"></div>
                </div>
            </div>
            <div class="dashboard-progress-item">
                <div class="dashboard-progress-header">
                    <span>Comments Received</span>
                    <span class="dashboard-breakdown-value">@Model.TotalCommentsReceived</span>
                </div>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill dashboard-progress-fill-info" 
                         style="width: @(Model.TotalEngagement > 0 ? (Model.TotalCommentsReceived * 100.0 / Model.TotalEngagement) : 0)%"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Most Popular Content -->
    <div class="dashboard-popular-grid">
        @if (Model.HasMostPopularRecipe)
        {
            <div class="dashboard-popular-card">
                <h5 class="dashboard-popular-title">🏆 Most Popular Recipe</h5>
                <h6 class="dashboard-popular-name">@Model.MostPopularRecipeTitle</h6>
                <div class="dashboard-popular-badges">
                    <span class="dashboard-badge dashboard-badge-success">❤️ @Model.MostPopularRecipeSaveCount saves</span>
                </div>
                <a asp-controller="Recipe" asp-action="Details" asp-route-id="@Model.MostPopularRecipeId" 
                   class="btn-ghost">View Recipe</a>
            </div>
        }

        @if (Model.HasMostPopularMealPlan)
        {
            <div class="dashboard-popular-card">
                <h5 class="dashboard-popular-title">🏆 Most Popular Meal Plan</h5>
                <h6 class="dashboard-popular-name">@Model.MostPopularMealPlanName</h6>
                <div class="dashboard-popular-badges">
                    <span class="dashboard-badge dashboard-badge-success">❤️ @Model.MostPopularMealPlanSaveCount saves</span>
                </div>
                <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.MostPopularMealPlanId" 
                   class="btn-ghost">View Meal Plan</a>
            </div>
        }

        @if (!Model.HasMostPopularRecipe && !Model.HasMostPopularMealPlan)
        {
            <div class="dashboard-section-card">
                <div class="dashboard-empty-state">
                    <h5 class="dashboard-empty-title">No content created yet</h5>
                    <p class="dashboard-empty-text">Start creating recipes and meal plans to see your statistics!</p>
                    <div class="dashboard-empty-actions">
                        <a asp-controller="Recipe" asp-action="Create" class="btn-primary">Create Recipe</a>
                        <a asp-controller="MealPlan" asp-action="Create" class="btn-ghost">Create Meal Plan</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
