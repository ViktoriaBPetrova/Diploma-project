@model HealthyRecipes.Web.ViewModels.Statistics.RecipeStatisticsViewModel

@if (Model != null)
{
    <div class="stats-partial-card">
        <h5 class="stats-partial-title">📊 Recipe Statistics</h5>
        
        <div class="stats-partial-grid">
            <!-- Save Count -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-success">@Model.SaveCount</div>
                <small class="stats-partial-label">Saves</small>
            </div>

            <!-- Average Rating -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-warning" title="@Model.AverageRatingDisplay">
                    @Model.RatingStars
                </div>
                <small class="stats-partial-label">@Model.RatingCount ratings</small>
            </div>

            <!-- Comments -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-info">@Model.CommentCount</div>
                <small class="stats-partial-label">Comments</small>
            </div>

            <!-- Meal Plan Usage -->
            <div class="stats-partial-item">
                <div class="stats-partial-value stats-partial-value-primary">@Model.MealPlanUsageCount</div>
                <small class="stats-partial-label">In Meal Plans</small>
            </div>
        </div>

        @if (Model.AverageRating > 0)
        {
            <div class="stats-partial-footer">
                <small class="stats-partial-footer-text">
                    Average rating: <strong>@Model.AverageRatingDisplay</strong> / 5.0
                </small>
            </div>
        }
    </div>
}
else
{
    <div class="stats-partial-card">
        <p class="stats-partial-unavailable">Statistics unavailable</p>
    </div>
}
