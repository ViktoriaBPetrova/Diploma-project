@model HealthyRecipes.Web.ViewModels.Ingredient.CreateIngredientViewModel
@{ ViewData["Title"] = "Add Ingredient"; }

<div class="container ingredient-form-container">
    <div class="ingredient-form-wrapper">
        <a asp-action="Index" class="ingredient-form-hint">← Ingredients</a>
        <h1 class="ingredient-form-heading">Add Ingredient</h1>
        <p class="page-subtitle ingredient-form-subtitle">Manually add a custom ingredient with nutritional data</p>

        <div class="form-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Name">Name *</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Brown Rice" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Brand">Brand</label>
                        <input asp-for="Brand" class="form-control" placeholder="Optional" />
                    </div>
                </div>

                <p class="ingredient-nutrition-label">Per 100g</p>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CaloriesPer100g">Calories (kcal) *</label>
                        <input asp-for="CaloriesPer100g" type="number" step="0.1" class="form-control" placeholder="365" />
                        <span asp-validation-for="CaloriesPer100g" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ProteinPer100g">Protein (g) *</label>
                        <input asp-for="ProteinPer100g" type="number" step="0.1" class="form-control" placeholder="7.5" />
                        <span asp-validation-for="ProteinPer100g" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CarbsPer100g">Carbs (g) *</label>
                        <input asp-for="CarbsPer100g" type="number" step="0.1" class="form-control" placeholder="76" />
                        <span asp-validation-for="CarbsPer100g" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="FatPer100g">Fat (g) *</label>
                        <input asp-for="FatPer100g" type="number" step="0.1" class="form-control" placeholder="2.8" />
                        <span asp-validation-for="FatPer100g" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="ingredient-form-actions">
                    <button type="submit" class="btn-primary">Add ingredient</button>
                    <a asp-action="Index" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

