@model HealthyRecipes.Web.Models.Ingredient.EditIngredientViewModel
@{
    ViewData["Title"] = "Edit Ingredient";
}

<div class="ingredient-edit-container">
    <div class="ingredient-edit-header">
        <h1>Edit Ingredient</h1>
        <p class="subtitle">Update ingredient information and nutritional values</p>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="ingredient-edit-form">
        @Html.AntiForgeryToken()
        
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-section">
            <h2>Basic Information</h2>
            
            <div class="form-group">
                <label asp-for="Name" class="form-label">Ingredient Name *</label>
                <input asp-for="Name" class="form-input" placeholder="e.g., Chicken Breast, Brown Rice" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Brand" class="form-label">Brand (Optional)</label>
                <input asp-for="Brand" class="form-input" placeholder="e.g., Organic Valley" />
                <span asp-validation-for="Brand" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-section">
            <h2>Nutrition Facts (per 100g)</h2>
            <p class="form-help">All values should be per 100 grams of the ingredient</p>

            <div class="nutrition-grid">
                <div class="form-group">
                    <label asp-for="CaloriesPer100g" class="form-label">Calories (kcal) *</label>
                    <input asp-for="CaloriesPer100g" type="number" step="0.1" class="form-input" />
                    <span asp-validation-for="CaloriesPer100g" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ProteinPer100g" class="form-label">Protein (g) *</label>
                    <input asp-for="ProteinPer100g" type="number" step="0.1" class="form-input" />
                    <span asp-validation-for="ProteinPer100g" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="CarbsPer100g" class="form-label">Carbohydrates (g) *</label>
                    <input asp-for="CarbsPer100g" type="number" step="0.1" class="form-input" />
                    <span asp-validation-for="CarbsPer100g" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FatPer100g" class="form-label">Fat (g) *</label>
                    <input asp-for="FatPer100g" type="number" step="0.1" class="form-input" />
                    <span asp-validation-for="FatPer100g" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Save Changes</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .ingredient-edit-container {
        max-width: 800px;
        margin: 0 auto;
        padding: var(--space-xl);
    }

    .ingredient-edit-header {
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-lg);
        border-bottom: 2px solid var(--border);
    }

    .ingredient-edit-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        color: var(--forest);
        margin: 0 0 var(--space-sm) 0;
    }

    .subtitle {
        font-size: 1rem;
        color: var(--sage);
        margin: 0;
    }

    .validation-summary {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: var(--radius);
        padding: var(--space-md);
        margin-bottom: var(--space-lg);
        color: #721c24;
    }

    .ingredient-edit-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
    }

    .form-section {
        background: var(--parchment);
        padding: var(--space-lg);
        border-radius: var(--radius-lg);
    }

    .form-section h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        color: var(--forest);
        margin: 0 0 var(--space-sm) 0;
    }

    .form-help {
        font-size: 0.875rem;
        color: var(--sage);
        margin: 0 0 var(--space-md) 0;
    }

    .form-group {
        margin-bottom: var(--space-md);
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--forest);
        margin-bottom: var(--space-xs);
        font-size: 0.875rem;
    }

    .form-input {
        width: 100%;
        padding: var(--space-sm) var(--space-md);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 1rem;
        background: white;
        color: var(--charcoal);
        transition: border-color 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--sage);
        box-shadow: 0 0 0 3px rgba(90, 125, 92, 0.1);
    }

    .form-input::placeholder {
        color: #999;
    }

    .nutrition-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: var(--space-md);
    }

    .field-validation-error {
        display: block;
        color: #d9534f;
        font-size: 0.875rem;
        margin-top: var(--space-xs);
    }

    .form-actions {
        display: flex;
        gap: var(--space-md);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--border);
    }

    .btn-submit,
    .btn-cancel {
        padding: var(--space-md) var(--space-xl);
        border-radius: var(--radius);
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-submit {
        background: var(--forest);
        color: white;
        flex: 1;
    }

    .btn-submit:hover {
        background: var(--sage);
    }

    .btn-cancel {
        background: white;
        color: var(--charcoal);
        border: 1px solid var(--border);
        flex: 0 0 auto;
        min-width: 120px;
    }

    .btn-cancel:hover {
        background: var(--parchment);
        border-color: var(--sage);
        color: var(--charcoal);
    }

    @@media (max-width: 768px) {
        .ingredient-edit-container {
            padding: var(--space-md);
        }

        .nutrition-grid {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column-reverse;
        }

        .btn-submit,
        .btn-cancel {
            width: 100%;
        }
    }
</style>
