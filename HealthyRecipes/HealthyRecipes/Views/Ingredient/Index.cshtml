@model HealthyRecipes.Web.ViewModels.Ingredient.IngredientIndexViewModel
@{ ViewData["Title"] = "Ingredients"; }

<div class="container">
    <!-- Advanced Filter Panel -->
    <div class="filter-panel">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="filter-header" onclick="toggleFilters()">
                <h3>🔍 Advanced Filters</h3>
                <button type="button" class="btn-ghost" id="toggleBtn">Show Filters</button>
            </div>

            <div class="filter-content recipe-filter-content-hidden" id="filterContent">

                <!-- Search Bar -->
                <div class="filter-section ingredient-search-form">
                    <label>Search</label>
                    <input type="text" name="SearchTerm" value="@Model.Filter.SearchTerm"
                           placeholder="Search ingredients…" class="form-control search-bar" />
                </div>

                <!-- Macronutrients -->
                <div class="filter-section">
                    <h4>Macronutrients</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Calories</label>
                            <div class="range-inputs">
                                <input type="number" name="MinCalories" value="@Model.Filter.MinCalories"
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxCalories" value="@Model.Filter.MaxCalories"
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Protein (g)</label>
                            <div class="range-inputs">
                                <input type="number" name="MinProtein" value="@Model.Filter.MinProtein"
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxProtein" value="@Model.Filter.MaxProtein"
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Carbs (g)</label>
                            <div class="range-inputs">
                                <input type="number" name="MinCarbs" value="@Model.Filter.MinCarbs"
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxCarbs" value="@Model.Filter.MaxCarbs"
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Fat (g)</label>
                            <div class="range-inputs">
                                <input type="number" name="MinFat" value="@Model.Filter.MinFat"
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxFat" value="@Model.Filter.MaxFat"
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="filter-group" style="margin-top: 1rem;">
                            <label class="checkbox-label">
                                <input type="checkbox" name="ExcludeUserAllergies" value="true"
                                       @(Model.Filter.ExcludeUserAllergies ? "checked" : "") />
                                <span>Exclude my allergens for you</span>
                            </label>
                        </div>
                    }
                

                <!-- Sorting -->
                <div class="filter-section">
                    <h4>Sort Results</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Sort By</label>
                            <select name="SortBy" class="form-control">
                                <option value="CreatedAt" selected="@(Model.Filter.SortBy == "CreatedAt")">Date Created</option>
                                <option value="Calories" selected="@(Model.Filter.SortBy == "Calories")">Calories</option>
                                <option value="Protein" selected="@(Model.Filter.SortBy == "Protein")">Protein</option>
                                <option value="Carbs" selected="@(Model.Filter.SortBy == "Carbs")">Carbs</option>
                                <option value="Fat" selected="@(Model.Filter.SortBy == "Fat")">Fat</option>
                                <option value="PrepTime" selected="@(Model.Filter.SortBy == "PrepTime")">Prep Time</option>
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Order</label>
                            <select name="SortOrder" class="form-control">
                                <option value="asc" selected="@(Model.Filter.SortOrder == "asc")">Ascending</option>
                                <option value="desc" selected="@(Model.Filter.SortOrder == "desc")">Descending</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="filter-actions">
                    <button type="submit" class="btn-primary">Apply Filters</button>
                    <a asp-action="Index" class="btn-ghost">Reset All</a>
                </div>
            </div>
        </form>
    </div>
    <div class="page-header">
        <div class="page-header-row">
            <div>
                <h1>Ingredients</h1>
                <p class="page-subtitle">Browse and manage your allergy list</p>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="Create" class="btn-primary">+ Add ingredient</a>
            }
        </div>
    </div>

    @if (Model.Ingredients.Any())
    {
        <div class="ingredient-table-wrapper">
            <table class="ingredient-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Brand</th>
                        <th>Calories / 100g</th>
                        <th>Protein</th>
                        <th>Carbs</th>
                        <th>Fat</th>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <th>Allergy</th>
                            <th>Favorite</th>
                        }
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ing in Model.Ingredients)
                    {
                        <tr>
                            <td>
                                @ing.Name
                                @if (ing.IsAllergen)
                                {
                                    <span class="allergen-mark"> ⚠️</span>
                                }
                            </td>
                            <td>@(ing.Brand ?? "—")</td>
                            <td>@ing.CaloriesPer100g.ToString("F0") kcal</td>
                            <td>@ing.ProteinPer100g.ToString("F1")g</td>
                            <td>@ing.CarbsPer100g.ToString("F1")g</td>
                            <td>@ing.FatPer100g.ToString("F1")g</td>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <td>
                                    <form asp-action="ToggleAllergy" asp-route-id="@ing.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="ingredient-allergy-btn btn-@(ing.IsAllergen ? "danger" : "ghost")">
                                            @(ing.IsAllergen ? "Remove" : "Mark")
                                        </button>
                                    </form>
                                </td>
                                <td>
                                    
                                        <form asp-action="ToggleSave" asp-route-id="@ing.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-save @(ing.IsSaved ? "saved" : "")">
                                                @(ing.IsSaved ? "♥ Saved" : "♡ Save")
                                            </button>
                                        </form>
                                    
                                </td>
                            }
                            <td>

                                <form asp-action="Details" asp-route-id="@ing.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-save">
                                        Details
                                    </button>
                                </form>

                            </td>
                        </tr>

                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">🥕</div>
            <h3>No ingredients found</h3>
            <p>@(string.IsNullOrEmpty(Model.SearchQuery) ? "No ingredients yet. Add the first one!" : "Try a different search.")</p>
        </div>
    }
</div>

@functions {
    Dictionary<string, string> GetCurrentFilters(HealthyRecipes.Web.ViewModels.Ingredient.IngredientFilterViewModel filter, int page)
    {
        var dict = new Dictionary<string, string>();

        if (!string.IsNullOrEmpty(filter.SearchTerm)) dict["SearchTerm"] = filter.SearchTerm;
        if (filter.MinCalories.HasValue) dict["MinCalories"] = filter.MinCalories.ToString();
        if (filter.MaxCalories.HasValue) dict["MaxCalories"] = filter.MaxCalories.ToString();
        if (filter.MinProtein.HasValue) dict["MinProtein"] = filter.MinProtein.ToString();
        if (filter.MaxProtein.HasValue) dict["MaxProtein"] = filter.MaxProtein.ToString();
        if (filter.MinCarbs.HasValue) dict["MinCarbs"] = filter.MinCarbs.ToString();
        if (filter.MaxCarbs.HasValue) dict["MaxCarbs"] = filter.MaxCarbs.ToString();
        if (filter.MinFat.HasValue) dict["MinFat"] = filter.MinFat.ToString();
        if (filter.MaxFat.HasValue) dict["MaxFat"] = filter.MaxFat.ToString();
        if (!string.IsNullOrEmpty(filter.SortBy)) dict["SortBy"] = filter.SortBy;
        if (!string.IsNullOrEmpty(filter.SortOrder)) dict["SortOrder"] = filter.SortOrder;
        if (filter.ExcludeUserAllergies) dict["ExcludeUserAllergies"] = "true";


        dict["PageNumber"] = page.ToString();

        return dict;
    }
}

@section Scripts {
    <script>
        function toggleFilters() {
            const content = document.getElementById('filterContent');
            const btn = document.getElementById('toggleBtn');

            if (content.classList.contains('recipe-filter-content-hidden')) {
                content.classList.remove('recipe-filter-content-hidden');
                btn.textContent = 'Hide Filters';
            } else {
                content.classList.add('recipe-filter-content-hidden');
                btn.textContent = 'Show Filters';
            }
        }
    </script>
}

