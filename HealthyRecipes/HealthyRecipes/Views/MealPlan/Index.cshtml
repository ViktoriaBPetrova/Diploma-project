@model HealthyRecipes.Web.ViewModels.MealPlan.MealPlanIndexViewModel
@{ ViewData["Title"] = "Meal Plans"; }

<div class="container">
    <div class="page-header">
        <div class="page-header-row">
            <div>
                <h1>Meal Plans</h1>
                <p class="page-subtitle">Plan your week, hit your macros</p>
            </div>
            <a asp-action="Create" class="btn-primary">+ New Plan</a>
        </div>
    </div>

    <!-- Advanced Filter Panel -->
    <div class="filter-panel">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="filter-header" onclick="toggleFilters()">
                <h3>🔍 Advanced Filters</h3>
                <button type="button" class="btn-ghost" id="toggleBtn">Show Filters</button>
            </div>

            <div class="filter-content" id="filterContent" style="display: none;">
                
                <!-- Search Bar -->
                <div class="filter-section">
                    <label>Search</label>
                    <input type="text" name="SearchTerm" value="@Model.Filter.SearchTerm" 
                           placeholder="Search meal plans…" class="form-control" />
                </div>

                <!-- Daily Macronutrients -->
                <div class="filter-section">
                    <h4>Daily Macronutrients (per day)</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Calories / Day</label>
                            <div class="range-inputs">
                                <input type="number" name="MinCaloriesPerDay" value="@Model.Filter.MinCaloriesPerDay" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxCaloriesPerDay" value="@Model.Filter.MaxCaloriesPerDay" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Protein (g) / Day</label>
                            <div class="range-inputs">
                                <input type="number" name="MinProteinPerDay" value="@Model.Filter.MinProteinPerDay" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxProteinPerDay" value="@Model.Filter.MaxProteinPerDay" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Carbs (g) / Day</label>
                            <div class="range-inputs">
                                <input type="number" name="MinCarbsPerDay" value="@Model.Filter.MinCarbsPerDay" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxCarbsPerDay" value="@Model.Filter.MaxCarbsPerDay" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Fat (g) / Day</label>
                            <div class="range-inputs">
                                <input type="number" name="MinFatPerDay" value="@Model.Filter.MinFatPerDay" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxFatPerDay" value="@Model.Filter.MaxFatPerDay" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Plan Details -->
                <div class="filter-section">
                    <h4>Plan Details</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Number of Days</label>
                            <div class="range-inputs">
                                <input type="number" name="MinDays" value="@Model.Filter.MinDays" 
                                       placeholder="Min" min="1" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxDays" value="@Model.Filter.MaxDays" 
                                       placeholder="Max" min="1" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Max Prep Time / Day (minutes)</label>
                            <input type="number" name="MaxPreparationTimePerDay" 
                                   value="@Model.Filter.MaxPreparationTimePerDay" 
                                   placeholder="e.g., 60" min="0" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Categories -->
                <div class="filter-section">
                    <h4>Categories</h4>
                    <div class="category-checkboxes">
                        @foreach (var category in Model.Categories)
                        {
                            var isChecked = Model.Filter.CategoryIds?.Contains(category.Id) == true;
                            <label class="checkbox-label">
                                <input type="checkbox" name="CategoryIds" value="@category.Id" 
                                       @(isChecked ? "checked" : "") />
                                <span>@category.Name</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- Sorting -->
                <div class="filter-section">
                    <h4>Sort Results</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Sort By</label>
                            <select name="SortBy" class="form-control">
                                <option value="CreatedAt" selected="@(Model.Filter.SortBy == "CreatedAt" ? "selected" : null)">Newest First</option>
                            <option value="Calories" selected="@(Model.Filter.SortBy == "Calories" ? "selected" : null)">Calories</option>
                            <option value="Protein" selected="@(Model.Filter.SortBy == "Protein" ? "selected" : null)">Protein</option>
                            <option value="Carbs" selected="@(Model.Filter.SortBy == "Carbs" ? "selected" : null)">Carbs</option>
                            <option value="Fat" selected="@(Model.Filter.SortBy == "Fat" ? "selected" : null)">Fat</option>
                            <option value="Days" selected="@(Model.Filter.SortBy == "Days" ? "selected" : null)">Number of Days</option>
                            <option value="Name" selected="@(Model.Filter.SortBy == "Name" ? "selected" : null)">Name</option>
                            </select>
                        </div>

                        <div class="filter-group">
                            
                            <label>Order</label>
                            <select name="SortOrder" class="form-control">
                                <option value="asc" selected="@(Model.Filter.SortOrder == "asc" ? "selected" : null)">Low to High</option>
                                <option value="desc" selected="@(Model.Filter.SortOrder == "desc" ? "selected" : null)">High to Low</option>
                            </select>
                        </div>
                    </div>
                </div>

               
                <!-- Actions -->
                <div class="filter-actions">
                    <button type="submit" class="btn-primary">Apply Filters</button>
                    <a asp-action="Index" class="btn-ghost">Reset All</a>
                </div>

            </div>
        </form>
    </div>

    <!-- My Plans Section -->
    @if (Model.MyMealPlans.Any())
    {
        <h2 class="section-title">My Plans</h2>
        <div class="grid-2 meal-plan-index-grid">
            @foreach (var plan in Model.MyMealPlans)
            {
                <partial name="_MealPlanCard" model="plan" />
            }
        </div>

    }
    else
    {

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="empty-state">
                <div class="empty-state-icon">🥦</div>
            <h3>You haven`t created any MealPlans yet!</h3>
        </div>
        }
    }

    <!-- Browse All Plans Section (with filters) -->
    <h2 class="section-title">Browse All Plans</h2>
    
    @if (Model.TotalCount > 0)
    {
        <div class="meal-plan-results-info">
            <p>Showing @Model.BrowseAllMealPlans.Count() of @Model.TotalCount meal plans</p>
        </div>
    }

    @if (Model.BrowseAllMealPlans.Any())
    {
        <div class="grid-2">
            @foreach (var plan in Model.BrowseAllMealPlans)
            {
                <partial name="_MealPlanCard" model="plan" />
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @if (Model.PageNumber > 1)
                {
                    <a asp-action="Index" 
                       asp-all-route-data="@GetCurrentFilters(Model.Filter, Model.PageNumber - 1)"
                       class="btn-ghost">← Previous</a>
                }

                @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                {
                    @if (i == Model.PageNumber)
                    {
                        <span class="active">@i</span>
                    }
                    else
                    {
                        <a asp-action="Index" 
                           asp-all-route-data="@GetCurrentFilters(Model.Filter, i)">@i</a>
                    }
                }

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <a asp-action="Index" 
                       asp-all-route-data="@GetCurrentFilters(Model.Filter, Model.PageNumber + 1)"
                       class="btn-ghost">Next →</a>
                }
            </div>
        }
    }
    else if (!Model.MyMealPlans.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h3>No meal plans found</h3>
            <p>Try adjusting your filters or create your first meal plan.</p>
            <a asp-action="Create" class="btn-primary">Create a plan</a>
        </div>
    }
</div>

@functions {
    Dictionary<string, string> GetCurrentFilters(HealthyRecipes.Web.ViewModels.MealPlan.MealPlanFilterViewModel filter, int page)
    {
        var dict = new Dictionary<string, string>();
        
        if (!string.IsNullOrEmpty(filter.SearchTerm)) dict["SearchTerm"] = filter.SearchTerm;
        if (filter.MinCaloriesPerDay.HasValue) dict["MinCaloriesPerDay"] = filter.MinCaloriesPerDay.ToString();
        if (filter.MaxCaloriesPerDay.HasValue) dict["MaxCaloriesPerDay"] = filter.MaxCaloriesPerDay.ToString();
        if (filter.MinProteinPerDay.HasValue) dict["MinProteinPerDay"] = filter.MinProteinPerDay.ToString();
        if (filter.MaxProteinPerDay.HasValue) dict["MaxProteinPerDay"] = filter.MaxProteinPerDay.ToString();
        if (filter.MinCarbsPerDay.HasValue) dict["MinCarbsPerDay"] = filter.MinCarbsPerDay.ToString();
        if (filter.MaxCarbsPerDay.HasValue) dict["MaxCarbsPerDay"] = filter.MaxCarbsPerDay.ToString();
        if (filter.MinFatPerDay.HasValue) dict["MinFatPerDay"] = filter.MinFatPerDay.ToString();
        if (filter.MaxFatPerDay.HasValue) dict["MaxFatPerDay"] = filter.MaxFatPerDay.ToString();
        if (filter.MinDays.HasValue) dict["MinDays"] = filter.MinDays.ToString();
        if (filter.MaxDays.HasValue) dict["MaxDays"] = filter.MaxDays.ToString();
        if (filter.MaxPreparationTimePerDay.HasValue) dict["MaxPreparationTimePerDay"] = filter.MaxPreparationTimePerDay.ToString();
        if (!string.IsNullOrEmpty(filter.SortBy)) dict["SortBy"] = filter.SortBy;
        if (!string.IsNullOrEmpty(filter.SortOrder)) dict["SortOrder"] = filter.SortOrder;
        
        dict["PageNumber"] = page.ToString();
        
        return dict;
    }
}

@section Scripts {
    <script>
        function toggleFilters() {
            const content = document.getElementById('filterContent');
            const btn = document.getElementById('toggleBtn');
            
            if (content.style.display === 'none') {
                content.style.display = 'block';
                btn.textContent = 'Hide Filters';
            } else {
                content.style.display = 'none';
                btn.textContent = 'Show Filters';
            }
        }
    </script>

  
}
