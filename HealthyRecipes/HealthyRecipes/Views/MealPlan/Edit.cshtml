@model HealthyRecipes.Web.ViewModels.MealPlan.EditMealPlanViewModel
@{ ViewData["Title"] = "Edit Meal Plan"; }

<div class="container meal-plan-form-container">
    <div class="meal-plan-form-wrapper">
        <a asp-action="Details" asp-route-id="@Model.Id" class="meal-plan-form-hint">← Back to plan</a>
        <h1 class="meal-plan-form-label">Edit Meal Plan</h1>

        <div class="form-card">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Name">Plan name *</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="meal-plan-form-actions">
                    <button type="submit" class="btn-primary">Save changes</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

