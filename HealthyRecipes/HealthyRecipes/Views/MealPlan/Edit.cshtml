@model HealthyRecipes.Web.ViewModels.MealPlan.EditMealPlanViewModel
@{ ViewData["Title"] = "Edit Meal Plan"; }

<div class="container inline-style-1">
    <div class="inline-style-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="inline-style-3">← Back to plan</a>
        <h1 class="inline-style-4">Edit Meal Plan</h1>

        <div class="form-card">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Name">Plan name *</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="inline-style-5">
                    <button type="submit" class="btn-primary">Save changes</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <style>
    .inline-style-1 {
        padding-top:48px;
        padding-bottom:64px;
    }
    .inline-style-2 {
        max-width:560px;
        margin:0 auto;
    }
    .inline-style-3 {
        color:var(--muted);
        font-size:0.875rem;
    }
    .inline-style-4 {
        margin:16px 0 8px;
    }
    .inline-style-5 {
        display:flex;
        gap:12px;
        margin-top:8px;
    }
    </style>
}