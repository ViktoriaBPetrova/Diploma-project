@model HealthyRecipes.Web.ViewModels.MealPlan.CreateMealPlanViewModel
@{ ViewData["Title"] = "Create Meal Plan"; }

<div class="container inline-style-1">
    <div class="inline-style-2">
        <a asp-action="Index" class="inline-style-3">← My Meal Plans</a>
        <h1 class="inline-style-4">New Meal Plan</h1>
        <p class="page-subtitle inline-style-5">Give your plan a name and start building your week</p>

        <div class="form-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Name">Plan name *</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Summer Lean Bulk" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="What's the goal of this plan?"></textarea>
                </div>

                <div class="inline-style-6">
                    <button type="submit" class="btn-primary">Create plan</button>
                    <a asp-action="Index" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <style>
    .inline-style-1 {
        padding-top:48px;
        padding-bottom:64px;
    }
    .inline-style-2 {
        max-width:560px;
        margin:0 auto;
    }
    .inline-style-3 {
        color:var(--muted);
        font-size:0.875rem;
    }
    .inline-style-4 {
        margin:16px 0 8px;
    }
    .inline-style-5 {
        margin-bottom:36px;
    }
    .inline-style-6 {
        display:flex;
        gap:12px;
        margin-top:8px;
    }
    </style>
}