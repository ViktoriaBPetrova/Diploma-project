@model HealthyRecipes.Web.ViewModels.MealPlan.MealPlanDetailsViewModel
@{ ViewData["Title"] = Model.Name; }

<div class="container inline-style-1">

    <a asp-action="Index" class="inline-style-2">← My Meal Plans</a>

    <div class="inline-style-3">
        <div>
            <h1 class="inline-style-4">@Model.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="inline-style-5">@Model.Description</p>
            }
        </div>
        <div class="inline-style-6">
            <form asp-action="ToggleSave" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-save @(Model.IsSaved ? "saved" : "")">
                    @(Model.IsSaved ? "♥ Saved" : "♡ Save Plan")
                </button>
            </form>
            @if (!Model.IsFollowing)
            {
                <a asp-controller="MealPlanFollower" asp-action="StartFollowing" asp-route-id="@Model.Id" class="btn-primary">
                    📋 Start Following This Plan
                </a>
            }
            else
            {
                <a asp-controller="MealPlanFollower" asp-action="MyActivePlans" class="btn-ghost">
                    ✓ Already Following - View My Plans
                </a>
            }
            @if (Model.IsOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-ghost">Edit</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this plan?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">Delete</button>
                </form>
            }
        </div>
    </div>

    <!-- Weekly Totals -->
    <div class="inline-style-7">
        <div>
            <div class="inline-style-8">Weekly avg calories</div>
            <div class="inline-style-9">@Model.Calories.ToString("F0")</div>
        </div>
        <div>
            <div class="inline-style-10">Protein</div>
            <div class="inline-style-11">@Model.Protein.ToString("F0")<span class="inline-style-12">g</span></div>
        </div>
        <div>
            <div class="inline-style-13">Carbs</div>
            <div class="inline-style-14">@Model.Carbs.ToString("F0")<span class="inline-style-15">g</span></div>
        </div>
        <div>
            <div class="inline-style-16">Fat</div>
            <div class="inline-style-17">@Model.Fat.ToString("F0")<span class="inline-style-18">g</span></div>
        </div>
        <div>
            <div class="inline-style-19">Days planned</div>
            <div class="inline-style-20">@Model.Days.Count()</div>
        </div>
    </div>

    @if (Model.Days.Any())
    {
        @foreach (var day in Model.Days)
        {
            <div class="day-card">
                <div class="day-header">
                    <span class="day-title">Day @day.DayNumber — @day.DayOfWeek</span>
                    <div class="macro-row">
                        <span class="macro-pill cal inline-style-21">🔥 @day.Calories.ToString("F0")</span>
                    </div>
                </div>
                <div class="day-body">
                    @if (day.Meals.Any())
                    {
                        @foreach (var meal in day.Meals)
                        {
                            <div class="meal-item">
                                <div class="meal-type-label">@meal.Type</div>
                                <div class="macro-row inline-style-22">
                                    <span class="macro-pill cal">@meal.Calories.ToString("F0") kcal</span>
                                    <span class="macro-pill protein">P @meal.Protein.ToString("F0")g</span>
                                    <span class="macro-pill carbs">C @meal.Carbs.ToString("F0")g</span>
                                    <span class="macro-pill fat">F @meal.Fat.ToString("F0")g</span>
                                </div>
                                @if (meal.Recipes.Any())
                                {
                                    <div class="inline-style-23">
                                        @foreach (var recipe in meal.Recipes)
                                        {
                                            <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.RecipeId"
                                               class="inline-style-24">
                                                @(recipe.Info.Length > 50 ? recipe.Info[..50] + "…" : recipe.Info)
                                                <span class="inline-style-25">@recipe.Calories.ToString("F0") kcal</span>
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="inline-style-26">No recipes added to this meal.</p>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="inline-style-27">No meals for this day.</p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">📅</div>
            <h3>No days added yet</h3>
            <p>This meal plan doesn't have any days configured.</p>
        </div>
    }
</div>


