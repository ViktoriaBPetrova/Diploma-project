@model HealthyRecipes.Web.ViewModels.MealPlan.MealPlanDetailsViewModel
@{ ViewData["Title"] = Model.Name; }

<div class="container meal-plan-details-container">

    <a asp-action="Index" class="meal-plan-meta">← My Meal Plans</a>

    <div class="meal-plan-details-header">
        <div>
            <h1 class="day-header">@Model.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="meal-plan-meta">@Model.Description</p>
            }
        </div>
        <div class="meal-plan-tags">
            <form asp-action="ToggleSave" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-save @(Model.IsSaved ? "saved" : "")">
                    @(Model.IsSaved ? "♥ Saved" : "♡ Save Plan")
                </button>
            </form>
            @if (!Model.IsFollowing)
            {
                <a asp-controller="MealPlanFollower" asp-action="StartFollowing" asp-route-id="@Model.Id" class="btn-primary">
                    📋 Start Following This Plan
                </a>
            }
            else
            {
                <a asp-controller="MealPlanFollower" asp-action="MyActivePlans" class="btn-ghost">
                    ✓ Already Following - View My Plans
                </a>
            }
            @if (Model.IsOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-ghost">Edit</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this plan?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">Delete</button>
                </form>
            }
        </div>
    </div>

    <!-- Weekly Totals -->
    <div class="meal-plan-nutrition-summary">
        <div class="nutrition-stat">
            <div class="nutrition-stat-label">Weekly avg calories</div>
            <div class="nutrition-stat-value">@Model.Calories.ToString("F0")</div>
        </div>
        <div class="nutrition-stat">
            <div class="nutrition-stat-label">Protein</div>
            <div class="nutrition-stat-value">@Model.Protein.ToString("F0")<span class="nutrition-stat-unit">g</span></div>
        </div>
        <div class="nutrition-stat">
            <div class="nutrition-stat-label">Carbs</div>
            <div class="nutrition-stat-value">@Model.Carbs.ToString("F0")<span class="nutrition-stat-unit">g</span></div>
        </div>
        <div class="nutrition-stat">
            <div class="nutrition-stat-label">Fat</div>
            <div class="nutrition-stat-value">@Model.Fat.ToString("F0")<span class="nutrition-stat-unit">g</span></div>
        </div>
        <div class="nutrition-stat">
            <div class="nutrition-stat-label">Days planned</div>
            <div class="nutrition-stat-value">@Model.Days.Count()</div>
        </div>
    </div>

    @if (Model.Days.Any())
    {
        @foreach (var day in Model.Days)
        {
            <div class="day-card">
                <div class="day-header">
                    <span class="day-title">Day @day.DayNumber — @day.DayOfWeek</span>
                    <div class="macro-row">
                        <span class="macro-pill cal meal-plan-day-list">🔥 @day.Calories.ToString("F0")</span>
                    </div>
                </div>
                <div class="day-body">
                    @if (day.Meals.Any())
                    {
                        @foreach (var meal in day.Meals)
                        {
                            <div class="meal-item">
                                <div class="meal-type-label">@meal.Type</div>
                                <div class="macro-row day-header">
                                    <span class="macro-pill cal">@meal.Calories.ToString("F0") kcal</span>
                                    <span class="macro-pill protein">P @meal.Protein.ToString("F0")g</span>
                                    <span class="macro-pill carbs">C @meal.Carbs.ToString("F0")g</span>
                                    <span class="macro-pill fat">F @meal.Fat.ToString("F0")g</span>
                                </div>
                                @if (meal.Recipes.Any())
                                {
                                    <div class="day-meals">
                                        @foreach (var recipe in meal.Recipes)
                                        {
                                            <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.RecipeId"
                                               class="day-meal-link">
                                                @(recipe.Info.Length > 50 ? recipe.Info[..50] + "…" : recipe.Info)
                                                <span class="day-meal-recipes">@recipe.Calories.ToString("F0") kcal</span>
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="no-meals-message">No recipes added to this meal.</p>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="no-days-message">No meals for this day.</p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">📅</div>
            <h3>No days added yet</h3>
            <p>This meal plan doesn't have any days configured.</p>
        </div>
    }
</div>

