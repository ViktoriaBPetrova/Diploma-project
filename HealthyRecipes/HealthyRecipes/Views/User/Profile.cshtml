@model HealthyRecipes.Web.ViewModels.User.UserProfileViewModel
@{ ViewData["Title"] = "Profile"; }

<div class="container" style="padding-top:40px; padding-bottom:60px;">

    <div class="profile-header">
        <div class="profile-avatar">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
            }
            else
            {
                <span>👤</span>
            }
        </div>
        <div class="profile-info">
            <h1>@(string.IsNullOrWhiteSpace(Model.FullName) ? Model.UserName : Model.FullName)</h1>
            <p>@(string.IsNullOrEmpty(Model.Bio) ? "No bio yet." : Model.Bio)</p>
            <div class="profile-stats">
                <div>
                    <div class="profile-stat-value">@Model.RecipeCount</div>
                    <div class="profile-stat-label">Recipes</div>
                </div>
                <div>
                    <div class="profile-stat-value">@Model.MealPlanCount</div>
                    <div class="profile-stat-label">Meal Plans</div>
                </div>
                @if (Model.Height.HasValue)
                {
                    <div>
                        <div class="profile-stat-value">@Model.Height cm</div>
                        <div class="profile-stat-label">Height</div>
                    </div>
                }
                @if (Model.Weight.HasValue)
                {
                    <div>
                        <div class="profile-stat-value">@Model.Weight kg</div>
                        <div class="profile-stat-label">Weight</div>
                    </div>
                }
            </div>
        </div>
        @if (Model.IsCurrentUser)
        {
            <a asp-action="Edit" class="btn-ghost" style="margin-left:auto; color:white; border-color:rgba(255,255,255,0.4); align-self:flex-start;">Edit profile</a>
        }
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; flex-wrap:wrap;">

        <!-- Goals -->
        @if (Model.CalorieGoal.HasValue || Model.ProteinGoal.HasValue)
        {
            <div style="background:white; border-radius:var(--radius); border:1px solid var(--border); padding:28px;">
                <h3 style="margin-bottom:20px;">Daily Goals</h3>
                @if (Model.CalorieGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Calories</span><span>@Model.CalorieGoal kcal</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill cal" style="width:100%;"></div></div>
                    </div>
                }
                @if (Model.ProteinGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Protein</span><span>@Model.ProteinGoal g</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill protein" style="width:100%;"></div></div>
                    </div>
                }
                @if (Model.CarbsGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Carbs</span><span>@Model.CarbsGoal g</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill carbs" style="width:100%;"></div></div>
                    </div>
                }
                @if (Model.FatGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Fat</span><span>@Model.FatGoal g</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill fat" style="width:100%;"></div></div>
                    </div>
                }
            </div>
        }

        <!-- Allergies -->
        <div style="background:white; border-radius:var(--radius); border:1px solid var(--border); padding:28px;">
            <h3 style="margin-bottom:16px;">Allergies & Intolerances</h3>
            @if (Model.Allergies.Any())
            {
                <div class="tags" style="margin-bottom:16px;">
                    @foreach (var allergy in Model.Allergies)
                    {
                        <span class="tag tag-terracotta" style="display:inline-flex; align-items:center; gap:6px;">
                            ⚠️ @allergy.IngredientName
                            @if (Model.IsCurrentUser)
                            {
                                <form asp-action="RemoveAllergy" asp-route-ingredientId="@allergy.IngredientId" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" style="background:none; border:none; cursor:pointer; color:rgba(255,255,255,0.8); font-size:0.9rem; line-height:1;">✕</button>
                                </form>
                            }
                        </span>
                    }
                </div>
            }
            else
            {
                <p style="color:var(--muted); font-style:italic; margin-bottom:16px;">No allergies recorded.</p>
            }
            @if (Model.IsCurrentUser)
            {
                <a asp-controller="Ingredient" asp-action="Index" class="btn-ghost" style="font-size:0.875rem;">Manage allergies →</a>
            }
        </div>
    </div>

    @if (Model.IsCurrentUser)
    {
        <div style="margin-top:32px; display:flex; gap:12px;">
            <a asp-controller="Recipe" asp-action="Index" class="btn-ghost">Browse recipes</a>
            <a asp-controller="MealPlan" asp-action="Index" class="btn-primary">My meal plans</a>
        </div>
    }
</div>
