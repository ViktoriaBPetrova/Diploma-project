@model HealthyRecipes.Web.ViewModels.User.UserProfileViewModel
@{ ViewData["Title"] = "Profile"; }

<div class="container profile-container">

    <div class="profile-header">
        <div class="profile-avatar">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="Avatar" class="profile-avatar-img" />
            }
            else
            {
                <span>👤</span>
            }
        </div>
        <div class="profile-info">
            <h1>@(string.IsNullOrWhiteSpace(Model.FullName) ? Model.UserName : Model.FullName)</h1>
            <p>@(string.IsNullOrEmpty(Model.Bio) ? "No bio yet." : Model.Bio)</p>
            <div class="profile-stats">
                <div>
                    <div class="profile-stat-value">@Model.RecipeCount</div>
                    <div class="profile-stat-label">Recipes</div>
                </div>
                <div>
                    <div class="profile-stat-value">@Model.MealPlanCount</div>
                    <div class="profile-stat-label">Meal Plans</div>
                </div>
                @if (Model.Height.HasValue)
                {
                    <div>
                        <div class="profile-stat-value">@Model.Height cm</div>
                        <div class="profile-stat-label">Height</div>
                    </div>
                }
                @if (Model.Weight.HasValue)
                {
                    <div>
                        <div class="profile-stat-value">@Model.Weight kg</div>
                        <div class="profile-stat-label">Weight</div>
                    </div>
                }
            </div>
        </div>
        @if (Model.IsCurrentUser)
        {
            <a asp-action="Edit" class="btn-ghost profile-edit-btn">Edit profile</a>
        }
    </div>

    <div class="profile-content-grid">

        <!-- Goals -->
        @if (Model.CalorieGoal.HasValue || Model.ProteinGoal.HasValue)
        {
            <div class="profile-section-card">
                <h3 class="profile-section-title">Daily Goals</h3>
                @if (Model.CalorieGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Calories</span><span>@Model.CalorieGoal kcal</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill cal profile-goal-full"></div></div>
                    </div>
                }
                @if (Model.ProteinGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Protein</span><span>@Model.ProteinGoal g</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill protein profile-goal-full"></div></div>
                    </div>
                }
                @if (Model.CarbsGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Carbs</span><span>@Model.CarbsGoal g</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill carbs profile-goal-full"></div></div>
                    </div>
                }
                @if (Model.FatGoal.HasValue)
                {
                    <div class="goal-bar-wrap">
                        <div class="goal-bar-label"><span>Fat</span><span>@Model.FatGoal g</span></div>
                        <div class="goal-bar"><div class="goal-bar-fill fat profile-goal-full"></div></div>
                    </div>
                }
            </div>
        }

        <!-- Allergies -->
        <div class="profile-section-card">
            <h3 class="profile-allergy-title">Allergies & Intolerances</h3>
            @if (Model.Allergies.Any())
            {
                <div class="tags profile-allergy-tags">
                    @foreach (var allergy in Model.Allergies)
                    {
                        <span class="tag tag-terracotta profile-allergy-tag">
                            ⚠️ @allergy.IngredientName
                            @if (Model.IsCurrentUser)
                            {
                                <form asp-action="RemoveAllergy" asp-route-ingredientId="@allergy.IngredientId" method="post" class="profile-allergy-remove-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="profile-allergy-remove-btn">✕</button>
                                </form>
                            }
                        </span>
                    }
                </div>
            }
            else
            {
                <p class="profile-no-allergies">No allergies recorded.</p>
            }
            @if (Model.IsCurrentUser)
            {
                <a asp-controller="Ingredient" asp-action="Index" class="btn-ghost profile-manage-allergies-btn">Manage allergies →</a>
            }
        </div>
    </div>

    @if (Model.IsCurrentUser)
    {
        <div class="profile-actions">
            <a asp-controller="Recipe" asp-action="Index" class="btn-ghost">Browse recipes</a>
            <a asp-controller="MealPlan" asp-action="Index" class="btn-primary">My meal plans</a>
        </div>
    }
</div>
