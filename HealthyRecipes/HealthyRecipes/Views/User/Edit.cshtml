@model HealthyRecipes.Web.ViewModels.User.EditProfileViewModel
@{ ViewData["Title"] = "Edit Profile"; }

<div class="container inline-style-1">
    <div class="inline-style-2">
        <a asp-action="Profile" class="inline-style-3">← Back to profile</a>
        <h1 class="inline-style-4">Edit Profile</h1>
        <p class="page-subtitle inline-style-5">Update your personal details and nutrition goals</p>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors inline-style-6"></div>

            <div class="inline-style-7">
                <h3 class="inline-style-8">Personal Info</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName">First name</label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="LastName">Last name</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Bio">Bio</label>
                    <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Tell the community about yourself…"></textarea>
                </div>
                <div class="form-group">
                    <label asp-for="ImageUrl">Profile photo URL</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://…" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Height">Height (cm)</label>
                        <input asp-for="Height" type="number" step="0.1" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Weight">Weight (kg)</label>
                        <input asp-for="Weight" type="number" step="0.1" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="inline-style-9">
                <h3 class="inline-style-10">Nutrition Goals</h3>
                <p class="form-hint inline-style-11">Set your daily targets to track progress against your goals.</p>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CalorieGoal">Calories (kcal)</label>
                        <input asp-for="CalorieGoal" type="number" class="form-control" placeholder="2000" />
                    </div>
                    <div class="form-group">
                        <label asp-for="ProteinGoal">Protein (g)</label>
                        <input asp-for="ProteinGoal" type="number" class="form-control" placeholder="150" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CarbsGoal">Carbs (g)</label>
                        <input asp-for="CarbsGoal" type="number" class="form-control" placeholder="250" />
                    </div>
                    <div class="form-group">
                        <label asp-for="FatGoal">Fat (g)</label>
                        <input asp-for="FatGoal" type="number" class="form-control" placeholder="70" />
                    </div>
                </div>
            </div>

            <div class="inline-style-12">
                <button type="submit" class="btn-primary">Save changes</button>
                <a asp-action="Profile" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <style>
    .inline-style-1 {
        padding-top:48px;
        padding-bottom:64px;
    }
    .inline-style-2 {
        max-width:640px;
        margin:0 auto;
    }
    .inline-style-3 {
        color:var(--muted);
        font-size:0.875rem;
    }
    .inline-style-4 {
        margin:16px 0 8px;
    }
    .inline-style-5 {
        margin-bottom:36px;
    }
    .inline-style-6 {
        margin-bottom:16px;
    }
    .inline-style-7 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:24px;
    }
    .inline-style-8 {
        margin-bottom:20px;
    }
    .inline-style-9 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:24px;
    }
    .inline-style-10 {
        margin-bottom:8px;
    }
    .inline-style-11 {
        margin-bottom:20px;
    }
    .inline-style-12 {
        display:flex;
        gap:12px;
    }
    </style>
}