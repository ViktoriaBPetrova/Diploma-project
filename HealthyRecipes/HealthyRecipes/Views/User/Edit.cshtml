@model HealthyRecipes.Web.ViewModels.User.EditProfileViewModel
@{ ViewData["Title"] = "Edit Profile"; }

<div class="container profile-edit-container">
    <div class="profile-edit-wrapper">
        <a asp-action="Profile" class="profile-edit-hint">← Back to profile</a>
        <h1 class="profile-edit-heading">Edit Profile</h1>
        <p class="page-subtitle profile-edit-subtitle">Update your personal details and nutrition goals</p>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors profile-edit-validation-errors"></div>

            <div class="profile-edit-section">
                <h3 class="profile-edit-section-title">Personal Info</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName">First name</label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="LastName">Last name</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Bio">Bio</label>
                    <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Tell the community about yourself…"></textarea>
                </div>
                <div class="form-group">
                    <label asp-for="ImageUrl">Profile photo URL</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://…" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Height">Height (cm)</label>
                        <input asp-for="Height" type="number" step="0.1" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Weight">Weight (kg)</label>
                        <input asp-for="Weight" type="number" step="0.1" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="profile-edit-section">
                <h3 class="profile-edit-section-title">Nutrition Goals</h3>
                <p class="form-hint profile-edit-goals-hint">Set your daily targets to track progress against your goals.</p>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CalorieGoal">Calories (kcal)</label>
                        <input asp-for="CalorieGoal" type="number" class="form-control" placeholder="2000" />
                    </div>
                    <div class="form-group">
                        <label asp-for="ProteinGoal">Protein (g)</label>
                        <input asp-for="ProteinGoal" type="number" class="form-control" placeholder="150" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CarbsGoal">Carbs (g)</label>
                        <input asp-for="CarbsGoal" type="number" class="form-control" placeholder="250" />
                    </div>
                    <div class="form-group">
                        <label asp-for="FatGoal">Fat (g)</label>
                        <input asp-for="FatGoal" type="number" class="form-control" placeholder="70" />
                    </div>
                </div>
            </div>

            <div class="profile-edit-actions">
                <button type="submit" class="btn-primary">Save changes</button>
                <a asp-action="Profile" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>
