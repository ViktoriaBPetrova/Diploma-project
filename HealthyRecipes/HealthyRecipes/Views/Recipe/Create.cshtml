        color:var(--muted);
        font-size:0.875rem;
    }
    .inline-style-4 {
        margin:16px 0 8px;
    }
    .inline-style-5 {
        margin-bottom:36px;
    }
    .inline-style-6 {
        margin-bottom:16px;
    }
    .inline-style-7 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:24px;
    }
    .inline-style-8 {
        margin-bottom:20px;
    }
    .inline-style-9 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:24px;
    }
    .inline-style-10 {
        margin-bottom:20px;
    }
    .inline-style-11 {
        display:flex;
        flex-wrap:wrap;
        gap:10px;
    }
    .inline-style-12 {
        display:flex;
        align-items:center;
        gap:8px;
        cursor:pointer;
        background:var(--parchment);
        padding:8px 14px;
        border-radius:20px;
        border:1.5px solid var(--border);
        font-size:0.9rem;
    }
    .inline-style-13 {
        accent-color:var(--forest);
    }
    .inline-style-14 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:32px;
    }
    .inline-style-15 {
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:20px;
    }
    .inline-style-16 {
        font-size:0.875rem;
    }
    .inline-style-17 {
