@model HealthyRecipes.Web.ViewModels.Recipe.CreateRecipeViewModel
@{ ViewData["Title"] = "Create Recipe"; }

<div class="container recipe-form-container">
    <div class="recipe-form-wrapper">
        <a asp-action="Index" class="recipe-form-hint">← Back to recipes</a>
        <h1 class="recipe-form-heading">New Recipe</h1>
        <p class="page-subtitle recipe-form-subtitle">Share your healthy creation with the community</p>

        <form asp-action="Create" method="post" id="recipeForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors recipe-validation-errors"></div>

            <div class="recipe-form-section">
                <h3>Basic Info</h3>
                <div class="form-group">
                    <label asp-for="Title">Recipe Title *</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g., Healthy Chicken & Rice Bowl" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Info">Description *</label>
                    <textarea asp-for="Info" class="form-control" rows="4" placeholder="Describe your recipe, cooking method, and what makes it special…"></textarea>
                    <span asp-validation-for="Info" class="field-validation-error"></span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="PrepTime">Prep time (minutes)</label>
                        <input asp-for="PrepTime" type="number" class="form-control" placeholder="30" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Servings">Servings</label>
                        <input asp-for="Servings" type="number" class="form-control" placeholder="2" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Difficulty">Difficulty</label>
                        <select asp-for="Difficulty" class="form-control" asp-items="Html.GetEnumSelectList<HealthyRecipes.Data.Enums.Difficulty>()">
                            <option value="">— Select —</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="ImageUrl">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://…" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="VideoUrl">Video URL (optional)</label>
                    <input asp-for="VideoUrl" class="form-control" placeholder="https://youtube.com/…" />
                </div>
            </div>

            <div class="recipe-form-section">
                <h3>Categories</h3>
                <div class="recipe-category-grid">
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <label class="recipe-category-label">
                            <input type="checkbox" name="SelectedCategoryIds" value="@cat.Id" class="recipe-category-checkbox" />
                            @cat.Name
                        </label>
                    }
                </div>
            </div>

            <div class="recipe-form-section">
                <div class="recipe-ingredients-header">
                    <h3>Ingredients</h3>
                </div>
                
                <div class="ingredient-search-container">
                    <label>Search for ingredients</label>
                    <input type="text" 
                           id="ingredientSearch" 
                           class="form-control" 
                           placeholder="Start typing ingredient name…" 
                           autocomplete="off" />
                    <div id="searchResults" class="ingredient-search-results"></div>
                </div>

                <div id="ingredientsList">
                    <!-- Ingredients will be added here dynamically -->
                </div>
                
                <p class="form-hint">Search and select ingredients, then specify quantities. Nutrition totals will be calculated automatically.</p>
            </div>

            <div class="recipe-form-actions">
                <button type="submit" class="btn-primary">Create recipe</button>
                <a asp-action="Index" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
let ingredientCount = 0;
const addedIngredients = new Set();

// Ingredient search autocomplete
const searchInput = document.getElementById('ingredientSearch');
const searchResults = document.getElementById('searchResults');
let searchTimeout;

searchInput.addEventListener('input', function() {
    const term = this.value.trim();
    
    clearTimeout(searchTimeout);
    
    if (term.length < 2) {
        searchResults.innerHTML = '';
        searchResults.style.display = 'none';
        return;
    }
    
    searchTimeout = setTimeout(async () => {
        try {
            const response = await fetch(`/Recipe/SearchIngredients?term=${encodeURIComponent(term)}`);
            const ingredients = await response.json();
            
            if (ingredients.length === 0) {
                searchResults.innerHTML = '<div class="no-results">No ingredients found</div>';
                searchResults.style.display = 'block';
                return;
            }
            
            searchResults.innerHTML = ingredients.map(ing => `
                <div class="search-result-item" data-id="${ing.id}" data-name="${ing.name}" data-calories="${ing.caloriesPer100g}">
                    <span class="ingredient-name">${ing.name}</span>
                    <span class="ingredient-calories">${ing.caloriesPer100g} cal/100g</span>
                </div>
            `).join('');
            
            searchResults.style.display = 'block';
            
            // Add click handlers to search results
            document.querySelectorAll('.search-result-item').forEach(item => {
                item.addEventListener('click', function() {
                    addIngredient(
                        this.dataset.id,
                        this.dataset.name,
                        this.dataset.calories
                    );
                    searchInput.value = '';
                    searchResults.innerHTML = '';
                    searchResults.style.display = 'none';
                });
            });
            
        } catch (error) {
            console.error('Error searching ingredients:', error);
            searchResults.innerHTML = '<div class="error-message">Error loading results</div>';
            searchResults.style.display = 'block';
        }
    }, 300);
});

// Close search results when clicking outside
document.addEventListener('click', function(e) {
    if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.style.display = 'none';
    }
});

function addIngredient(id, name, calories) {
    if (addedIngredients.has(id)) {
        alert('This ingredient is already added');
        return;
    }
    
    addedIngredients.add(id);
    
    const list = document.getElementById('ingredientsList');
    const div = document.createElement('div');
    div.className = 'form-row recipe-ingredient-row';
    div.dataset.ingredientId = id;
    div.innerHTML = `
        <div class="ingredient-info">
            <strong>${name}</strong>
            <span class="ingredient-meta">${calories} cal/100g</span>
        </div>
        <div class="form-group ingredient-quantity-group">
            <label>Quantity (g)</label>
            <input type="number" 
                   name="Ingredients[${ingredientCount}].QuantityInGrams" 
                   class="form-control" 
                   placeholder="100" 
                   step="0.1" 
                   min="0.1" 
                   required />
        </div>
        <input type="hidden" name="Ingredients[${ingredientCount}].IngredientId" value="${id}" />
        <button type="button" onclick="removeIngredient(this, '${id}')" class="btn-danger recipe-remove-btn">✕</button>
    `;
    list.appendChild(div);
    ingredientCount++;
}

function removeIngredient(button, ingredientId) {
    addedIngredients.delete(ingredientId);
    button.parentElement.remove();
}
</script>
}
