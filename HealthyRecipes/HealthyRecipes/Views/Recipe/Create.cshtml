@model HealthyRecipes.Web.ViewModels.Recipe.CreateRecipeViewModel
@{
    ViewData["Title"] = "Create Recipe";
}

<div class="container recipe-form-container">
    <div class="recipe-form-wrapper">
        <a asp-action="Index" class="recipe-form-hint">← Back to recipes</a>
        <h1 class="recipe-form-heading">Create New Recipe</h1>
        <p class="page-subtitle recipe-form-subtitle">Share your healthy creation</p>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors recipe-validation-errors"></div>

            <div class="recipe-form-section">
                <h3>Basic Info</h3>
                <div class="form-group">
                    <label asp-for="Title">Recipe Title *</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Info">Description *</label>
                    <textarea asp-for="Info" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Info" class="field-validation-error"></span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="PrepTime">Prep time (minutes)</label>
                        <input asp-for="PrepTime" type="number" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Servings">Servings</label>
                        <input asp-for="Servings" type="number" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Difficulty">Difficulty</label>
                    <select asp-for="Difficulty" class="form-control" asp-items="Html.GetEnumSelectList<HealthyRecipes.Data.Enums.Difficulty>()">
                        <option value="">— Select —</option>
                    </select>
                </div>
            </div>

            <div class="recipe-form-section">
                <h3>Media</h3>

                @* Multiple Image Upload *@
                <div class="form-group">
                    <label>Recipe Images (up to 5)</label>
                    <div class="file-upload-wrapper" id="imageUploadWrapper">
                        <input asp-for="ImageFiles" type="file" accept="image/*" id="imageInput" multiple />
                        <label for="imageInput" class="file-upload-label image-upload">
                            <span class="file-upload-icon">📷</span>
                            <span class="file-upload-text">Choose images (max 5)</span>
                        </label>
                        <div class="file-upload-previews" id="imagePreviews" style="display: none;">
                            <!-- Image previews will be added here -->
                        </div>
                    </div>
                    <span asp-validation-for="ImageFiles" class="field-validation-error"></span>
                    <small class="file-upload-helper">Max 5MB per image. Formats: JPG, PNG, WebP</small>
                </div>

                @* Video Upload - Custom Styled *@
                <div class="form-group">
                    <label>Recipe Video</label>
                    <div class="file-upload-wrapper" id="videoUploadWrapper">
                        <input asp-for="VideoFile" type="file" accept="video/*" id="videoInput" />
                        <label for="videoInput" class="file-upload-label video-upload">
                            <span class="file-upload-icon">🎥</span>
                            <span class="file-upload-text">Choose a video</span>
                        </label>
                        <div class="file-upload-filename" id="videoFilename" style="display: none;">
                            <span class="filename-label">Selected:</span>
                            <span id="videoFilenameText"></span>
                            <button type="button" class="file-upload-remove" id="videoRemove">✕ Remove</button>
                        </div>
                    </div>
                    <span asp-validation-for="VideoFile" class="field-validation-error"></span>
                    <small class="file-upload-helper">Max 100MB. Formats: MP4, WebM</small>
                </div>
            </div>

            <div class="recipe-form-section">
                <h3>Categories</h3>
                <div class="recipe-category-grid">
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <label class="recipe-category-label">
                            <input type="checkbox" name="SelectedCategoryIds" value="@cat.Id"
                                   class="recipe-category-checkbox" />
                            @cat.Name
                        </label>
                    }
                </div>
            </div>

            <div class="recipe-form-section">
                <h3>Ingredients</h3>
                <div class="form-group">
                    <label>Search ingredients</label>
                    <div class="ingredient-search-wrapper">
                        <input type="text" id="ingredientSearch" class="form-control" placeholder="Start typing to search..." />
                        <div id="searchResults" class="search-results"></div>
                    </div>
                </div>
                <div id="ingredientsList" class="ingredients-list">
                    <!-- Ingredients will be added here dynamically -->
                </div>
            </div>

            <div class="recipe-form-actions">
                <button type="submit" class="btn-primary">Create Recipe</button>
                <a asp-action="Index" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Multiple Image Upload with Previews
        const imageInput = document.getElementById('imageInput');
        const imagePreviews = document.getElementById('imagePreviews');
        const imageUploadWrapper = document.getElementById('imageUploadWrapper');
        let selectedFiles = [];

        imageInput.addEventListener('change', function(e) {
            const files = Array.from(this.files);

            // Limit to 5 images
            if (files.length > 5) {
                alert('Maximum 5 images allowed');
                selectedFiles = files.slice(0, 5);
            } else {
                selectedFiles = files;
            }

            updateImagePreviews();
        });

        function updateImagePreviews() {
            imagePreviews.innerHTML = '';

            if (selectedFiles.length === 0) {
                imagePreviews.style.display = 'none';
                imageUploadWrapper.classList.remove('has-file');
                return;
            }

            imagePreviews.style.display = 'grid';
            imageUploadWrapper.classList.add('has-file');

            selectedFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.createElement('div');
                    preview.className = 'image-preview-item';
                    preview.innerHTML = `
                        <img src="${e.target.result}" alt="Preview ${index + 1}">
                        <button type="button" class="image-preview-remove" data-index="${index}">✕</button>
                        <span class="image-preview-label">${index === 0 ? 'Primary' : `Image ${index + 1}`}</span>
                    `;
                    imagePreviews.appendChild(preview);

                    // Attach remove handler
                    preview.querySelector('.image-preview-remove').addEventListener('click', function() {
                        removeImage(parseInt(this.dataset.index));
                    });
                };
                reader.readAsDataURL(file);
            });
        }

        function removeImage(index) {
            selectedFiles.splice(index, 1);

            // Update the file input
            const dt = new DataTransfer();
            selectedFiles.forEach(file => dt.items.add(file));
            imageInput.files = dt.files;

            updateImagePreviews();
        }

        // Video Upload (single file - existing logic)
        function setupFileUpload(inputId, wrapperId, filenameId, filenameTextId, removeId) {
            const input = document.getElementById(inputId);
            const wrapper = document.getElementById(wrapperId);
            const filenameDisplay = document.getElementById(filenameId);
            const filenameText = document.getElementById(filenameTextId);
            const removeBtn = document.getElementById(removeId);

            input.addEventListener('change', function(e) {
                if (this.files && this.files[0]) {
                    const file = this.files[0];
                    filenameText.textContent = file.name;
                    filenameDisplay.style.display = 'block';
                    wrapper.classList.add('has-file');
                } else {
                    filenameDisplay.style.display = 'none';
                    wrapper.classList.remove('has-file');
                }
            });

            removeBtn.addEventListener('click', function() {
                input.value = '';
                filenameDisplay.style.display = 'none';
                wrapper.classList.remove('has-file');
            });

            // Drag and drop support
            const label = wrapper.querySelector('.file-upload-label');

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                label.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                label.addEventListener(eventName, function() {
                    wrapper.classList.add('dragging');
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                label.addEventListener(eventName, function() {
                    wrapper.classList.remove('dragging');
                }, false);
            });

            label.addEventListener('drop', function(e) {
                const dt = e.dataTransfer;
                const files = dt.files;
                input.files = files;

                // Trigger change event
                const event = new Event('change', { bubbles: true });
                input.dispatchEvent(event);
            }, false);
        }

        // Initialize video upload
        setupFileUpload('videoInput', 'videoUploadWrapper', 'videoFilename', 'videoFilenameText', 'videoRemove');

        // Ingredient management
        let ingredientCount = 0;
        const addedIngredients = new Set();

        const searchInput = document.getElementById('ingredientSearch');
        const searchResults = document.getElementById('searchResults');
        let searchTimeout;

        searchInput.addEventListener('input', function() {
            const term = this.value.trim();

            clearTimeout(searchTimeout);

            if (term.length < 2) {
                searchResults.innerHTML = '';
                searchResults.style.display = 'none';
                return;
            }

            searchTimeout = setTimeout(async () => {
                try {
                    const response = await fetch(`/Recipe/SearchIngredients?term=${encodeURIComponent(term)}`);
                    const ingredients = await response.json();

                    if (ingredients.length === 0) {
                        searchResults.innerHTML = '<div class="no-results">No ingredients found</div>';
                        searchResults.style.display = 'block';
                        return;
                    }

                    searchResults.innerHTML = ingredients.map(ing => `
                        <div class="search-result-item" data-id="${ing.id}" data-name="${ing.name}" data-calories="${ing.caloriesPer100g}">
                            <span class="ingredient-name">${ing.name}</span>
                            <span class="ingredient-calories">${ing.caloriesPer100g} cal/100g</span>
                        </div>
                    `).join('');

                    searchResults.style.display = 'block';

                    document.querySelectorAll('.search-result-item').forEach(item => {
                        item.addEventListener('click', function() {
                            addIngredient(
                                this.dataset.id,
                                this.dataset.name,
                                this.dataset.calories
                            );
                            searchInput.value = '';
                            searchResults.innerHTML = '';
                            searchResults.style.display = 'none';
                        });
                    });

                } catch (error) {
                    console.error('Error searching ingredients:', error);
                    searchResults.innerHTML = '<div class="error-message">Error loading results</div>';
                    searchResults.style.display = 'block';
                }
            }, 300);
        });

        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.style.display = 'none';
            }
        });

        function addIngredient(id, name, calories) {
            if (addedIngredients.has(id)) {
                alert('This ingredient is already added');
                return;
            }

            addedIngredients.add(id);

            const list = document.getElementById('ingredientsList');
            const div = document.createElement('div');
            div.className = 'recipe-ingredient-row';
            div.dataset.ingredientId = id;
            div.innerHTML = `
                <div class="ingredient-header">
                    <div class="ingredient-info">
                        <strong>${name}</strong>
                        <span class="ingredient-meta">${calories} cal/100g</span>
                    </div>
                    <button type="button" onclick="removeIngredient(this, '${id}')" class="btn-danger recipe-remove-btn">✕ Remove</button>
                </div>

                <div class="measurement-controls">
                    <div class="measurement-inputs">
                        <div class="measurement-field">
                            <label>Grams</label>
                            <input type="number"
                                   step="0.1"
                                   min="0.1"
                                   data-unit="grams"
                                   class="form-control measurement-input"
                                   placeholder="0" />
                        </div>

                        <div class="measurement-field">
                            <label>Teaspoons</label>
                            <input type="number"
                                   step="0.1"
                                   min="0"
                                   data-unit="teaspoons"
                                   class="form-control measurement-input"
                                   placeholder="0" />
                        </div>

                        <div class="measurement-field">
                            <label>Tablespoons</label>
                            <input type="number"
                                   step="0.1"
                                   min="0"
                                   data-unit="tablespoons"
                                   class="form-control measurement-input"
                                   placeholder="0" />
                        </div>

                        <div class="measurement-field">
                            <label>Cups</label>
                            <input type="number"
                                   step="0.01"
                                   min="0"
                                   data-unit="cups"
                                   class="form-control measurement-input"
                                   placeholder="0" />
                        </div>

                        <div class="measurement-field">
                            <label>Coffee Cups</label>
                            <input type="number"
                                   step="0.01"
                                   min="0"
                                   data-unit="coffeecups"
                                   class="form-control measurement-input"
                                   placeholder="0" />
                        </div>

                        <div class="measurement-field">
                            <label>Millilitres</label>
                            <input type="number"
                                   step="1"
                                   min="0"
                                   data-unit="millilitres"
                                   class="form-control measurement-input"
                                   placeholder="0" />
                        </div>
                    </div>

                    <button type="button"
                            class="btn-convert"
                            onclick="convertMeasurements(this)">
                        🔄 Convert
                    </button>
                </div>
                        <input type="hidden" name="Ingredients[${ingredientCount}].IngredientId" value="${id}" />
                <input type="hidden" name="Ingredients[${ingredientCount}].QuantityInGrams" class="hidden-grams" value="0" />
                <input type="hidden" name="Ingredients[${ingredientCount}].QuantityInTeaspoons" class="hidden-teaspoons" value="0" />
                <input type="hidden" name="Ingredients[${ingredientCount}].QuantityInTablespoons" class="hidden-tablespoons" value="0" />
                <input type="hidden" name="Ingredients[${ingredientCount}].QuantityInCups" class="hidden-cups" value="0" />
                <input type="hidden" name="Ingredients[${ingredientCount}].QuantityInCoffeeCups" class="hidden-coffeecups" value="0" />
                <input type="hidden" name="Ingredients[${ingredientCount}].QuantityInMillilitres" class="hidden-millilitres" value="0" />
                <input type="hidden" name="Ingredients[${ingredientCount}].OriginalUnit" class="hidden-unit" value="grams" />
            `;
            list.appendChild(div);
            ingredientCount++;
        }

        function removeIngredient(button, ingredientId) {
            addedIngredients.delete(ingredientId);
            button.closest('.recipe-ingredient-row').remove();
        }

        async function convertMeasurements(button) {
            const row = button.closest('.recipe-ingredient-row');
            const inputs = row.querySelectorAll('.measurement-input');

            // Find which field has a value
            let sourceInput = null;
            let sourceValue = 0;

            for (const input of inputs) {
                const value = parseFloat(input.value);
                if (value && value > 0) {
                    sourceInput = input;
                    sourceValue = value;
                    break;
                }
            }

            if (!sourceInput) {
                alert('Please enter a quantity in at least one field');
                return;
            }

            const unit = sourceInput.dataset.unit;

            try {
                const response = await fetch('/Recipe/ConvertMeasurement', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        quantity: sourceValue,
                        fromUnit: unit
                    })
                });

                if (!response.ok) throw new Error('Conversion failed');

                const data = await response.json();

             
                        // Update all visible fields
        row.querySelector('[data-unit="grams"]').value = data.grams;
        row.querySelector('[data-unit="teaspoons"]').value = data.teaspoons;
        row.querySelector('[data-unit="tablespoons"]').value = data.tablespoons;
        row.querySelector('[data-unit="cups"]').value = data.cups;
        row.querySelector('[data-unit="coffeecups"]').value = data.coffeeCups;
        row.querySelector('[data-unit="millilitres"]').value = data.millilitres;

        // Update ALL hidden fields for form submission
        row.querySelector('.hidden-grams').value = data.grams;
        row.querySelector('.hidden-teaspoons').value = data.teaspoons;
        row.querySelector('.hidden-tablespoons').value = data.tablespoons;
        row.querySelector('.hidden-cups').value = data.cups;
        row.querySelector('.hidden-coffeecups').value = data.coffeeCups;
        row.querySelector('.hidden-millilitres').value = data.millilitres;
        row.querySelector('.hidden-unit').value = unit;

                // Visual feedback
                button.textContent = '✓ Converted';
                button.style.background = 'var(--sage)';
                setTimeout(() => {
                    button.textContent = '🔄 Convert';
                    button.style.background = '';
                }, 2000);

            } catch (error) {
                console.error('Conversion error:', error);
                alert('Failed to convert measurements. Please try again.');
            }
        }
    </script>

    <style>
        .file-upload-previews {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .image-preview-item {
            position: relative;
            aspect-ratio: 1;
            border-radius: var(--radius);
            overflow: hidden;
            border: 2px solid var(--border);
        }

            .image-preview-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .image-preview-remove {
            position: absolute;
            top: 0.25rem;
            right: 0.25rem;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--charcoal);
            color: white;
            border: none;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

            .image-preview-remove:hover {
                opacity: 1;
            }

        .image-preview-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
            color: white;
            padding: 0.5rem 0.25rem 0.25rem;
            font-size: 11px;
            text-align: center;
        }

        /* Measurement conversion styles */
        .recipe-ingredient-row {
            background: var(--parchment);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: var(--space-md);
            margin-bottom: var(--space-md);
        }

        .ingredient-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: var(--space-md);
        }

        .ingredient-info {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .ingredient-meta {
            color: var(--forest);
            font-size: 0.875rem;
            opacity: 0.8;
        }

        .measurement-controls {
            display: flex;
            gap: var(--space-md);
            align-items: flex-end;
        }

        .measurement-inputs {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: var(--space-sm);
            flex: 1;
        }

        .measurement-field {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

            .measurement-field label {
                font-size: 0.875rem;
                color: var(--forest);
                font-weight: 500;
            }

        .measurement-input {
            padding: 0.5rem;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            font-size: 0.875rem;
        }

        .btn-convert {
            padding: 0.75rem 1.5rem;
            background: var(--gold);
            color: white;
            border: none;
            border-radius: var(--radius);
            cursor: pointer;
            font-weight: 500;
            white-space: nowrap;
            transition: all 0.2s;
            height: fit-content;
        }

            .btn-convert:hover {
                background: var(--forest);
                transform: translateY(-1px);
            }

        .recipe-remove-btn {
            padding: 0.5rem 1rem;
            background: transparent;
            color: var(--charcoal);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            cursor: pointer;
            font-size: 0.875rem;
            transition: all 0.2s;
        }

            .recipe-remove-btn:hover {
                background: #dc3545;
                color: white;
                border-color: #dc3545;
            }
    </style>
}