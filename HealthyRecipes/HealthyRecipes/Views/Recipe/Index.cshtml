@model HealthyRecipes.Web.ViewModels.Recipe.RecipeIndexViewModel
@{ ViewData["Title"] = "Recipes"; }

<div class="container">
    <div class="page-header">
        <div class="page-header-row">
            <div>
                <h1>Recipes</h1>
                <p class="page-subtitle">Discover, save, and cook healthy meals</p>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="Create" class="btn-primary">+ New Recipe</a>
            }
        </div>
    </div>

    <!-- Advanced Filter Panel -->
    <div class="filter-panel">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="filter-header" onclick="toggleFilters()">
                <h3>🔍 Advanced Filters</h3>
                <button type="button" class="btn-ghost" id="toggleBtn">Show Filters</button>
            </div>

            <div class="filter-content recipe-filter-content-hidden" id="filterContent">
                
                <!-- Search Bar -->
                <div class="filter-section">
                    <label>Search</label>
                    <input type="text" name="SearchTerm" value="@Model.Filter.SearchTerm" 
                           placeholder="Search recipes…" class="form-control" />
                </div>

                <!-- Macronutrients -->
                <div class="filter-section">
                    <h4>Macronutrients</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Calories</label>
                            <div class="range-inputs">
                                <input type="number" name="MinCalories" value="@Model.Filter.MinCalories" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxCalories" value="@Model.Filter.MaxCalories" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Protein (g)</label>
                            <div class="range-inputs">
                                <input type="number" name="MinProtein" value="@Model.Filter.MinProtein" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxProtein" value="@Model.Filter.MaxProtein" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Carbs (g)</label>
                            <div class="range-inputs">
                                <input type="number" name="MinCarbs" value="@Model.Filter.MinCarbs" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxCarbs" value="@Model.Filter.MaxCarbs" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Fat (g)</label>
                            <div class="range-inputs">
                                <input type="number" name="MinFat" value="@Model.Filter.MinFat" 
                                       placeholder="Min" min="0" class="form-control" />
                                <span>-</span>
                                <input type="number" name="MaxFat" value="@Model.Filter.MaxFat" 
                                       placeholder="Max" min="0" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Time & Difficulty -->
                <div class="filter-section">
                    <h4>Cooking Details</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Max Prep Time (minutes)</label>
                            <input type="number" name="MaxPreparationTime" 
                                   value="@Model.Filter.MaxPreparationTime" 
                                   placeholder="e.g., 30" min="0" class="form-control" />
                        </div>

                        <div class="filter-group">
                            <label>Difficulty</label>
                            <select name="DifficultyLevel" class="form-control">
                                <option value="">Any</option>
                                <option value="Easy" selected="@(Model.Filter.DifficultyLevel == "Easy")">Easy</option>
                                <option value="Medium" selected="@(Model.Filter.DifficultyLevel == "Medium")">Medium</option>
                                <option value="Hard" selected="@(Model.Filter.DifficultyLevel == "Hard")">Hard</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Categories -->
                <div class="filter-section">
                    <h4>Categories</h4>
                    <div class="category-checkboxes">
                        @foreach (var category in Model.Categories)
                        {
                            var isChecked = Model.Filter.CategoryIds?.Contains(category.Id) == true;
                            <label class="checkbox-label">
                                <input type="checkbox" name="CategoryIds" value="@category.Id" 
                                       @(isChecked ? "checked" : "") />
                                <span>@category.Name</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- Ingredients -->
                <div class="filter-section">
                    <h4>Ingredients</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Must Include</label>
                            <input type="text" id="includeInput"
                                   value="@(Model.Filter.IncludeIngredients != null ? string.Join(", ", Model.Filter.IncludeIngredients) : "")" 
                                   placeholder="e.g., chicken, broccoli" class="form-control" />
                            <small>Comma-separated ingredients</small>
                        </div>

                        <div class="filter-group">
                            <label>Must Exclude</label>
                            <input type="text" id="excludeInput"
                                   value="@(Model.Filter.ExcludeIngredients != null ? string.Join(", ", Model.Filter.ExcludeIngredients) : "")" 
                                   placeholder="e.g., peanuts, dairy" class="form-control" />
                            <small>Comma-separated ingredients</small>
                        </div>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="filter-group" style="margin-top: 1rem;">
                            <label class="checkbox-label">
                                <input type="checkbox" name="ExcludeUserAllergies" value="true"
                                       @(Model.Filter.ExcludeUserAllergies ? "checked" : "") />
                                <span>Exclude recipes with my allergens for you</span>
                            </label>
                        </div>
                    }
                </div>

                <!-- Sorting -->
                <div class="filter-section">
                    <h4>Sort Results</h4>
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Sort By</label>
                            <select name="SortBy" class="form-control">  
                                <option value="CreatedAt" selected="@(Model.Filter.SortBy == "CreatedAt")">Date Created</option>
                                <option value="Calories" selected="@(Model.Filter.SortBy == "Calories")">Calories</option>
                                <option value="Protein" selected="@(Model.Filter.SortBy == "Protein")">Protein</option>
                                <option value="Carbs" selected="@(Model.Filter.SortBy == "Carbs")">Carbs</option>
                                <option value="Fat" selected="@(Model.Filter.SortBy == "Fat")">Fat</option>
                                <option value="PrepTime" selected="@(Model.Filter.SortBy == "PrepTime")">Prep Time</option>
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Order</label>
                            <select name="SortOrder" class="form-control">
                                <option value="asc" selected="@(Model.Filter.SortOrder == "asc")">Ascending</option>
                                <option value="desc" selected="@(Model.Filter.SortOrder == "desc")">Descending</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="filter-actions">
                    <button type="submit" class="btn-primary">Apply Filters</button>
                    <a asp-action="Index" class="btn-ghost">Reset All</a>
                </div>

            </div>
        </form>
    </div>

    <!-- Quick Category Filter Pills -->
    <div class="filter-row">
        <a asp-action="Index" class="filter-pill @(Model.Filter.CategoryIds?.Count == 0 || Model.Filter.CategoryIds == null ? "active" : "")">All</a>
        @foreach (var cat in Model.Categories)
        {
            var isActive = Model.Filter.CategoryIds?.Contains(cat.Id) == true && Model.Filter.CategoryIds.Count == 1;
            <a asp-action="Index" asp-route-CategoryIds="@cat.Id"
               class="filter-pill @(isActive ? "active" : "")">@cat.Name</a>
        }
    </div>

    <!-- My Recipes Section -->
    @if (Model.MyRecipes.Any())
    {
        <h2 class="section-title">My Recipes</h2>
        <div class="grid-3 recipe-index-grid">
            @foreach (var recipe in Model.MyRecipes)
            {
                <partial name="_RecipeCard" model="recipe" />
            }
        </div>

    }
    else
    {

        @if (User.Identity?.IsAuthenticated == true)
        {

            <div class="empty-state">
                <div class="empty-state-icon">🥦</div>
            <h3>You haven`t created any recipes yet!</h3>
        </div>
        }
    }

    <!-- Browse All Plans Section (with filters) -->
    <h2 class="section-title">Browse All Recipes</h2>

    <!-- Results Info -->
    @if (Model.TotalCount > 0)
    {
        <div class="recipe-index-results-info">
            <p>Showing @Model.Recipes.Count() of @Model.TotalCount recipes</p>
        </div>
    }

    <!-- Recipe Grid -->
    @if (Model.Recipes.Any())
    {
        <div class="grid-3">
            @foreach (var recipe in Model.Recipes)
            {
                <partial name="_RecipeCard" model="recipe" />
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-action="Index" 
                       asp-all-route-data="@GetCurrentFilters(Model.Filter, Model.CurrentPage - 1)"
                       class="btn-ghost">← Previous</a>
                }

                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    @if (i == Model.CurrentPage)
                    {
                        <span class="active">@i</span>
                    }
                    else
                    {
                        <a asp-action="Index" 
                           asp-all-route-data="@GetCurrentFilters(Model.Filter, i)">@i</a>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-action="Index" 
                       asp-all-route-data="@GetCurrentFilters(Model.Filter, Model.CurrentPage + 1)"
                       class="btn-ghost">Next →</a>
                }
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">🥦</div>
            <h3>No recipes found</h3>
            <p>Try adjusting your filters or search terms.</p>
            <a asp-action="Index" class="btn-ghost">Clear all filters</a>
        </div>
    }
</div>

@functions {
    Dictionary<string, string> GetCurrentFilters(HealthyRecipes.Web.ViewModels.Recipe.RecipeFilterViewModel filter, int page)
    {
        var dict = new Dictionary<string, string>();
        
        if (!string.IsNullOrEmpty(filter.SearchTerm)) dict["SearchTerm"] = filter.SearchTerm;
        if (filter.MinCalories.HasValue) dict["MinCalories"] = filter.MinCalories.ToString();
        if (filter.MaxCalories.HasValue) dict["MaxCalories"] = filter.MaxCalories.ToString();
        if (filter.MinProtein.HasValue) dict["MinProtein"] = filter.MinProtein.ToString();
        if (filter.MaxProtein.HasValue) dict["MaxProtein"] = filter.MaxProtein.ToString();
        if (filter.MinCarbs.HasValue) dict["MinCarbs"] = filter.MinCarbs.ToString();
        if (filter.MaxCarbs.HasValue) dict["MaxCarbs"] = filter.MaxCarbs.ToString();
        if (filter.MinFat.HasValue) dict["MinFat"] = filter.MinFat.ToString();
        if (filter.MaxFat.HasValue) dict["MaxFat"] = filter.MaxFat.ToString();
        if (filter.MaxPreparationTime.HasValue) dict["MaxPreparationTime"] = filter.MaxPreparationTime.ToString();
        if (!string.IsNullOrEmpty(filter.DifficultyLevel)) dict["DifficultyLevel"] = filter.DifficultyLevel;
        if (!string.IsNullOrEmpty(filter.SortBy)) dict["SortBy"] = filter.SortBy;
        if (!string.IsNullOrEmpty(filter.SortOrder)) dict["SortOrder"] = filter.SortOrder;
        if (filter.ExcludeUserAllergies) dict["ExcludeUserAllergies"] = "true";


        dict["PageNumber"] = page.ToString();
        
        return dict;
    }
}

@section Scripts {
    <script>
        function toggleFilters() {
            const content = document.getElementById('filterContent');
            const btn = document.getElementById('toggleBtn');
            
            if (content.classList.contains('recipe-filter-content-hidden')) {
                content.classList.remove('recipe-filter-content-hidden');
                btn.textContent = 'Hide Filters';
            } else {
                content.classList.add('recipe-filter-content-hidden');
                btn.textContent = 'Show Filters';
            }
        }

        // Handle ingredient lists on form submit
        document.getElementById('filterForm').addEventListener('submit', function(e) {
            const includeInput = document.getElementById('includeInput');
            const excludeInput = document.getElementById('excludeInput');
            
            // Clear existing hidden inputs
            document.querySelectorAll('input[name="IncludeIngredients"]').forEach(el => el.remove());
            document.querySelectorAll('input[name="ExcludeIngredients"]').forEach(el => el.remove());
            
            // Add include ingredients as hidden inputs
            if (includeInput.value.trim()) {
                includeInput.value.split(',').forEach(ingredient => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'IncludeIngredients';
                    input.value = ingredient.trim();
                    this.appendChild(input);
                });
            }
            
            // Add exclude ingredients as hidden inputs
            if (excludeInput.value.trim()) {
                excludeInput.value.split(',').forEach(ingredient => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'ExcludeIngredients';
                    input.value = ingredient.trim();
                    this.appendChild(input);
                });
            }
        });
    </script>
}
