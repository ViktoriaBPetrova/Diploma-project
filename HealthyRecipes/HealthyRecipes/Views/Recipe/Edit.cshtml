@model HealthyRecipes.Web.ViewModels.Recipe.EditRecipeViewModel
@{ ViewData["Title"] = "Edit Recipe"; }

<div class="container inline-style-1">
    <div class="inline-style-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="inline-style-3">← Back to recipe</a>
        <h1 class="inline-style-4">Edit Recipe</h1>
        <p class="page-subtitle inline-style-5">Update your recipe details</p>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors inline-style-6"></div>

            <div class="inline-style-7">
                <h3 class="inline-style-8">Basic Info</h3>
                <div class="form-group">
                    <label asp-for="Title">Recipe Title *</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Info">Description *</label>
                    <textarea asp-for="Info" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Info" class="field-validation-error"></span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="PrepTime">Prep time (minutes)</label>
                        <input asp-for="PrepTime" type="number" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Servings">Servings</label>
                        <input asp-for="Servings" type="number" class="form-control" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Difficulty">Difficulty</label>
                        <select asp-for="Difficulty" class="form-control" asp-items="Html.GetEnumSelectList<HealthyRecipes.Data.Enums.Difficulty>()">
                            <option value="">— Select —</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="ImageUrl">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="VideoUrl">Video URL</label>
                    <input asp-for="VideoUrl" class="form-control" />
                </div>
            </div>

            <div class="inline-style-9">
                <h3 class="inline-style-10">Categories</h3>
                <div class="inline-style-11">
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <label class="inline-style-12">
                            <input type="checkbox" name="SelectedCategoryIds" value="@cat.Id"
                                   @(Model.SelectedCategoryIds.Contains(cat.Id) ? "checked" : "")
                                   class="inline-style-13" />
                            @cat.Name
                        </label>
                    }
                </div>
            </div>

            <div class="inline-style-14">
                <button type="submit" class="btn-primary">Save changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <style>
    .inline-style-1 {
        padding-top:48px;
        padding-bottom:64px;
    }
    .inline-style-2 {
        max-width:720px;
        margin:0 auto;
    }
    .inline-style-3 {
        color:var(--muted);
        font-size:0.875rem;
    }
    .inline-style-4 {
        margin:16px 0 8px;
    }
    .inline-style-5 {
        margin-bottom:36px;
    }
    .inline-style-6 {
        margin-bottom:16px;
    }
    .inline-style-7 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:24px;
    }
    .inline-style-8 {
        margin-bottom:20px;
    }
    .inline-style-9 {
        background:white;
        border-radius:var(--radius-lg);
        padding:36px;
        border:1px solid var(--border);
        box-shadow:var(--shadow);
        margin-bottom:24px;
    }
    .inline-style-10 {
        margin-bottom:20px;
    }
    .inline-style-11 {
        display:flex;
        flex-wrap:wrap;
        gap:10px;
    }
    .inline-style-12 {
        display:flex;
        align-items:center;
        gap:8px;
        cursor:pointer;
        background:var(--parchment);
        padding:8px 14px;
        border-radius:20px;
        border:1.5px solid var(--border);
        font-size:0.9rem;
    }
    .inline-style-13 {
        accent-color:var(--forest);
    }
    .inline-style-14 {
        display:flex;
        gap:12px;
    }
    </style>
}