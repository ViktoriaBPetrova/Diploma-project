<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – NutriTrack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MealPlans.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar">
        <div class="nav-inner">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-leaf">🌿</span>
                <span class="brand-text">NutriTrack</span>
            </a>
            <div class="nav-links">
                <a asp-controller="Statistics" asp-action="Dashboard" class="nav-link">My Statistics</a>
                <a asp-controller="MealPlanFollower" asp-action="MyActivePlans" asp-area="">My Active Plans</a>
                <a asp-controller="Recipe" asp-action="Index">Recipes</a>
                <a asp-controller="MealPlan" asp-action="Index">Meal Plans</a>
                <a asp-controller="Ingredient" asp-action="Index">Ingredients</a>
                
            </div>
            </div>
            <div class="nav-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="User" asp-action="Profile" class="nav-avatar-link">
                        <span class="nav-username">@User.Identity.Name</span>
                    </a>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="inline-style-1">
                        <button type="submit" class="btn-ghost">Log out</button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-ghost">Sign in</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn-primary">Get started</a>
                }
            </div>
        </div>
    </nav>

    <div class="page-wrapper">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">@TempData["Error"]</div>
        }
        @RenderBody()
    </div>

    <footer class="footer">
        <div class="footer-inner">
            <p>© @DateTime.Now.Year NutriTrack — Eat well, live better</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


@section Scripts {
    <style>
    .inline-style-1 {
        display:inline
    }
    </style>
}