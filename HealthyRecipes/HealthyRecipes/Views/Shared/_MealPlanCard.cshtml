@model HealthyRecipes.Web.ViewModels.MealPlan.MealPlanCardViewModel
<div class="card meal-plan-card">
    <div class="meal-plan-header">
        <div>
            <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.Id" class="meal-plan-link">
                <div class="card-title">@Model.Name</div>
            </a>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="meal-plan-description">@(Model.Description.Length > 80 ? Model.Description[..80] + "…" : Model.Description)</p>
            }
        </div>
        <span class="meal-plan-days">@Model.DayCount days</span>
    </div>
    <div class="macro-row meal-plan-macros">
        <span class="macro-pill cal">🔥 @Model.Calories.ToString("F0")</span>
        <span class="macro-pill protein">P @Model.Protein.ToString("F0")g</span>
        <span class="macro-pill carbs">C @Model.Carbs.ToString("F0")g</span>
        <span class="macro-pill fat">F @Model.Fat.ToString("F0")g</span>
    </div>
    <div class="meal-plan-actions">
        <a asp-controller="MealPlan" asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View plan</a>
        @if (Model.IsOwner)
        {
            <a asp-controller="MealPlan" asp-action="Edit" asp-route-id="@Model.Id" class="btn-ghost">Edit</a>
        }
        <form asp-controller="MealPlan" asp-action="ToggleSave" asp-route-id="@Model.Id" method="post" class="meal-plan-save-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-save @(Model.IsSaved ? "saved" : "")">
                @(Model.IsSaved ? "♥ Saved" : "♡ Save")
            </button>
        </form>
    </div>
</div>

<style>
    .meal-plan-card {
        padding: 24px;
    }

    .meal-plan-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
    }

    .meal-plan-link {
        text-decoration: none;
    }

    .meal-plan-description {
        font-size: 0.875rem;
        color: var(--muted);
        margin-top: 4px;
    }

    .meal-plan-days {
        font-size: 0.875rem;
        color: var(--muted);
        white-space: nowrap;
    }

    .meal-plan-macros {
        margin-bottom: 16px;
    }

    .meal-plan-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .meal-plan-actions .btn-ghost {
            font-size: 0.875rem;
        }

    .meal-plan-save-form {
        margin-left: auto;
    }
</style>