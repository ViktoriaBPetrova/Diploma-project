@model IEnumerable<HealthyRecipes.Web.ViewModels.MealPlan.IngredientMealViewModel>

@{
    var mealId = ViewData["MealId"]?.ToString() ?? "";
    var isOwner = ViewData["IsOwner"] as bool? ?? false;
}

@* Ingredients Section - Uses Recipe Details CSS *@
<div class="meal-ingredients-container" style="margin-top: 1rem;">
    @if (Model != null && Model.Any())
    {
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
            <h6 style="font-size: 0.875rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin: 0;">
                Side Ingredients
            </h6>
            
            @* Unit Selector *@
            <select id="unit-selector-@mealId" class="form-control" style="width: auto; padding: 0.5rem; font-size: 0.875rem;">
                <option value="original">As Entered</option>
                <option value="grams">Grams (g)</option>
                <option value="teaspoons">Teaspoons (tsp)</option>
                <option value="tablespoons">Tablespoons (tbsp)</option>
                <option value="cups">Cups</option>
                <option value="coffeecups">Coffee Cups</option>
                <option value="millilitres">Millilitres (ml)</option>
            </select>
        </div>

        <ul class="recipe-ingredients-list" id="ingredients-list-@mealId" style="list-style: none; padding: 0; margin: 0 0 1rem 0;">
            @foreach (var ingredient in Model)
            {
                <li class="recipe-ingredient-item"
                    data-ingredient-id="@ingredient.IngredientId"
                    data-grams="@ingredient.QuantityInGrams"
                    data-teaspoons="@(ingredient.QuantityInTeaspoons ?? 0)"
                    data-tablespoons="@(ingredient.QuantityInTablespoons ?? 0)"
                    data-cups="@(ingredient.QuantityInCups ?? 0)"
                    data-coffeecups="@(ingredient.QuantityInCoffeeCups ?? 0)"
                    data-millilitres="@(ingredient.QuantityInMillilitres ?? 0)"
                    data-original-unit="@(ingredient.OriginalUnit ?? "grams")"
                    data-original-formatted="@ingredient.FormattedQuantity">

                    <span class="ingredient-quantity">@ingredient.FormattedQuantity </span>
                    <a asp-action="Details" asp-controller="Ingredient" asp-route-id="@ingredient.IngredientId"> @ingredient.IngredientName
                    </a>
                    
                    @if (isOwner)
                    {
                        <button type="button"
                                class="btn-delete-ingredient"
                                data-ingredient-id="@ingredient.IngredientId"
                                data-meal-id="@mealId"
                                title="Remove ingredient">
                            <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                            </svg>
                        </button>
                    }
                </li>
            }
        </ul>
    }

    @* Add Ingredient Button and Search Panel (only for owners) - Uses Recipe Details CSS *@
    @if (isOwner)
    {
        <div class="ingredient-search-toggle-container" >
            <button type="button" class="btn-search-icon" id="add-ingredient-btn-@mealId" data-meal-id="@mealId" title="Add ingredient">
                <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
                </svg>
            </button>

            <div class="ingredient-search-expandable" id="ingredient-search-container-@mealId" data-meal-id="@mealId" style="max-width: 100%; box-sizing: border-box;">
                <div class="ingredient-search-wrapper" style="max-width: 100%; box-sizing: border-box;">
                    <svg class="ingredient-search-icon-left" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
                    </svg>
                    <input type="text"
                           id="ingredient-search-@mealId"
                           class="ingredient-search-input-expand"
                           data-meal-id="@mealId"
                           placeholder="Search ingredients..."
                           autocomplete="off">
                    <button type="button" class="search-close-icon" id="close-search-btn-@mealId" data-meal-id="@mealId" title="Close">
                        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z" />
                        </svg>
                    </button>
                    <div id="search-results-@mealId" class="search-results" data-meal-id="@mealId"></div>
                </div>

                <div id="ingredient-quantity-form-@mealId" class="ingredient-quantity-form-overlay" data-meal-id="@mealId">
                    <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem; margin-bottom: 0.75rem;">
                        <div style="display: flex; flex-direction: column;">
                            <label style="font-size: 0.75rem; font-weight: 600; color: var(--forest); margin-bottom: 0.25rem;">Grams</label>
                            <input type="number" step="0.1" min="0" data-unit="grams" class="form-control measurement-input-compact" placeholder="0" style="padding: 0.375rem 0.5rem; font-size: 0.875rem;">
                        </div>
                        <div style="display: flex; flex-direction: column;">
                            <label style="font-size: 0.75rem; font-weight: 600; color: var(--forest); margin-bottom: 0.25rem;">tsp</label>
                            <input type="number" step="0.1" min="0" data-unit="teaspoons" class="form-control measurement-input-compact" placeholder="0" style="padding: 0.375rem 0.5rem; font-size: 0.875rem;">
                        </div>
                        <div style="display: flex; flex-direction: column;">
                            <label style="font-size: 0.75rem; font-weight: 600; color: var(--forest); margin-bottom: 0.25rem;">tbsp</label>
                            <input type="number" step="0.1" min="0" data-unit="tablespoons" class="form-control measurement-input-compact" placeholder="0" style="padding: 0.375rem 0.5rem; font-size: 0.875rem;">
                        </div>
                        <div style="display: flex; flex-direction: column;">
                            <label style="font-size: 0.75rem; font-weight: 600; color: var(--forest); margin-bottom: 0.25rem;">Cups</label>
                            <input type="number" step="0.01" min="0" data-unit="cups" class="form-control measurement-input-compact" placeholder="0" style="padding: 0.375rem 0.5rem; font-size: 0.875rem;">
                        </div>
                        <div style="display: flex; flex-direction: column;">
                            <label style="font-size: 0.75rem; font-weight: 600; color: var(--forest); margin-bottom: 0.25rem;">ml</label>
                            <input type="number" step="1" min="0" data-unit="millilitres" class="form-control measurement-input-compact" placeholder="0" style="padding: 0.375rem 0.5rem; font-size: 0.875rem;">
                        </div>
                    </div>
                    <button type="button" class="btn-secondary convert-measurement-btn" id="convert-measurement-btn-@mealId" data-meal-id="@mealId" style="width: 100%; margin-bottom: 0.5rem;">🔄 Convert</button>
                    <div style="display: flex; gap: 0.5rem;">
                        <button type="button" class="btn-primary confirm-add-ingredient" id="confirm-add-ingredient-@mealId" data-meal-id="@mealId" style="flex: 1;">Add</button>
                        <button type="button" class="btn-ghost cancel-add-ingredient" id="cancel-add-ingredient-@mealId" data-meal-id="@mealId" style="flex: 1;">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>


<script>
    (function() {
        const mealId = '@mealId';
        let selectedIngredientId = null;
        let selectedIngredientName = null;
        let searchTimeout;

        // Get elements
        const addIngredientBtn = document.getElementById(`add-ingredient-btn-${mealId}`);
        const searchContainer = document.getElementById(`ingredient-search-container-${mealId}`);
        const searchInput = document.getElementById(`ingredient-search-${mealId}`);
        const searchResults = document.getElementById(`search-results-${mealId}`);
        const quantityForm = document.getElementById(`ingredient-quantity-form-${mealId}`);
        const confirmBtn = document.getElementById(`confirm-add-ingredient-${mealId}`);
        const cancelBtn = document.getElementById(`cancel-add-ingredient-${mealId}`);
        const ingredientsList = document.getElementById(`ingredients-list-${mealId}`);
        const unitSelector = document.getElementById(`unit-selector-${mealId}`);
        const closeSearchBtn = document.getElementById(`close-search-btn-${mealId}`);

        // Show/hide search container
        if (addIngredientBtn && searchContainer) {
            addIngredientBtn.addEventListener('click', function() {
                searchContainer.classList.add('active');
                addIngredientBtn.style.opacity = '0';
                addIngredientBtn.style.pointerEvents = 'none';
                setTimeout(() => {
                    if (searchInput) searchInput.focus();
                }, 300);
            });
        }

        // Close button
        if (closeSearchBtn) {
            closeSearchBtn.addEventListener('click', function() {
                if (searchContainer) searchContainer.classList.remove('active');
                if (addIngredientBtn) {
                    addIngredientBtn.style.opacity = '1';
                    addIngredientBtn.style.pointerEvents = 'auto';
                }
                resetIngredientForm();
            });
        }

        // Ingredient search
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                const term = this.value.trim();
                clearTimeout(searchTimeout);

                if (term.length < 2) {
                    searchResults.innerHTML = '';
                    searchResults.style.display = 'none';
                    return;
                }

                searchTimeout = setTimeout(async () => {
                    try {
                        const response = await fetch(`/Recipe/SearchIngredients?term=${encodeURIComponent(term)}`);
                        const ingredients = await response.json();

                        if (ingredients.length === 0) {
                            searchResults.innerHTML = '<div class="search-result-item">No ingredients found</div>';
                            searchResults.style.display = 'block';
                            return;
                        }

                        searchResults.innerHTML = ingredients.map(ing => `
                            <div class="search-result-item" data-id="${ing.id}" data-name="${ing.name}">
                                <div class="search-result-name">${ing.name}</div>
                                <div class="search-result-meta">${ing.caloriesPer100g} cal/100g</div>
                            </div>
                        `).join('');

                        searchResults.style.display = 'block';

                        document.querySelectorAll(`#search-results-${mealId} .search-result-item`).forEach(item => {
                            item.addEventListener('click', function() {
                                selectIngredient(this.dataset.id, this.dataset.name);
                            });
                        });

                    } catch (error) {
                        console.error('Search error:', error);
                        searchResults.innerHTML = '<div class="search-result-item">Error loading results</div>';
                        searchResults.style.display = 'block';
                    }
                }, 300);
            });
        }

        function selectIngredient(id, name) {
            selectedIngredientId = id;
            selectedIngredientName = name;
            searchInput.value = name;
            searchResults.style.display = 'none';
            quantityForm.style.display = 'block';
        }

        // Cancel button
        if (cancelBtn) {
            cancelBtn.addEventListener('click', resetIngredientForm);
        }

        // Convert measurement button
        const convertBtn = document.getElementById(`convert-measurement-btn-${mealId}`);
        if (convertBtn) {
            convertBtn.addEventListener('click', async function() {
                const inputs = quantityForm.querySelectorAll('.measurement-input-compact');
                let sourceInput = null;
                let sourceValue = 0;

                // Clear previous conversion markers
                inputs.forEach(input => {
                    input.removeAttribute('data-converted-from');
                });

                for (const input of inputs) {
                    const value = parseFloat(input.value);
                    if (value && value > 0) {
                        sourceInput = input;
                        sourceValue = value;
                        break;
                    }
                }

                if (!sourceInput) {
                    alert('Please enter a quantity in at least one field');
                    return;
                }

                const unit = sourceInput.dataset.unit;

                try {
                    // Try to get the token - it might be in a form or standalone
                    let token = null;
                    const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');

                    if (tokenElement && tokenElement.value) {
                        token = tokenElement.value;
                    } else {
                        console.error('Anti-forgery token not found or empty!');
                        console.log('Token element:', tokenElement);
                        console.log('Token value:', tokenElement?.value);
                        alert('Security token missing. Please refresh the page and try again.');
                        return;
                    }

                    const response = await fetch('/MealPlan/ConvertMeasurement', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            quantity: sourceValue,
                            fromUnit: unit
                        })
                    });

                    if (!response.ok) throw new Error('Conversion failed');

                    const data = await response.json();

                    // Update all fields
                    quantityForm.querySelector('[data-unit="grams"]').value = data.grams;
                    quantityForm.querySelector('[data-unit="teaspoons"]').value = data.teaspoons;
                    quantityForm.querySelector('[data-unit="tablespoons"]').value = data.tablespoons;
                    quantityForm.querySelector('[data-unit="cups"]').value = data.cups;
                    quantityForm.querySelector('[data-unit="millilitres"]').value = data.millilitres;

                    // Mark the original source field
                    sourceInput.setAttribute('data-converted-from', 'true');

                    // Visual feedback
                    convertBtn.textContent = '✓ Converted';
                    convertBtn.style.background = 'var(--sage)';
                    setTimeout(() => {
                        convertBtn.textContent = '🔄 Convert';
                        convertBtn.style.background = '';
                    }, 1500);

                } catch (error) {
                    console.error('Conversion error:', error);
                    alert('Failed to convert measurements');
                }
            });
        }

        // Confirm add ingredient
        if (confirmBtn) {
            confirmBtn.addEventListener('click', async function() {
                const inputs = quantityForm.querySelectorAll('.measurement-input-compact');
                let quantity = 0;
                let unit = 'grams';

                // Finds the field that was the SOURCE of conversion
                const convertedFrom = quantityForm.querySelector('[data-converted-from="true"]');

                if (convertedFrom) {
                    quantity = parseFloat(convertedFrom.value);
                    unit = convertedFrom.dataset.unit;
                } else {
                    // No conversion happened - finds the first non-empty field
                    for (const input of inputs) {
                        const value = parseFloat(input.value);
                        if (value && value > 0) {
                            quantity = value;
                            unit = input.dataset.unit;
                            break;
                        }
                    }
                }

                if (!selectedIngredientId || !quantity) {
                    alert('Please fill in a quantity');
                    return;
                }

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    console.log('Adding ingredient:', {
                        mealId: mealId,
                        ingredientId: selectedIngredientId,
                        quantity: quantity,
                        unit: unit,
                        hasToken: !!token
                    });

                    const response = await fetch('/MealPlan/AddIngredientToMeal', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: new URLSearchParams({
                            mealId: mealId,
                            ingredientId: selectedIngredientId,
                            quantity: quantity,
                            unit: unit,
                            __RequestVerificationToken: token
                        })
                    });

                    console.log('Response status:', response.status);
                    console.log('Response ok:', response.ok);
                    console.log('Response headers:', {
                        contentType: response.headers.get('content-type')
                    });

                    // Check if response is JSON
                    const contentType = response.headers.get('content-type');
                    if (!contentType || !contentType.includes('application/json')) {
                        const text = await response.text();
                        console.error('Response is not JSON! Content type:', contentType);
                        console.error('Response body:', text.substring(0, 500));
                        alert('Server returned an error (not JSON). Check console for details.');
                        return;
                    }

                    const result = await response.json();
                    console.log('Add result:', result);

                    if (result.success) {
                        console.log('Success! Reloading page...');
                        location.reload();
                    } else {
                        console.error('Failed to add:', result.message);
                        alert(result.message || 'Failed to add ingredient');
                    }

                } catch (error) {
                    console.error('EXCEPTION in add ingredient:', error);
                    console.error('Error type:', error.name);
                    console.error('Error message:', error.message);
                    console.error('Error stack:', error.stack);
                    alert('Failed to add ingredient: ' + error.message);
                }
            });
        }

        function resetIngredientForm() {
            selectedIngredientId = null;
            selectedIngredientName = null;
            if (searchInput) searchInput.value = '';

            if (quantityForm) {
                quantityForm.querySelectorAll('.measurement-input-compact').forEach(input => {
                    input.value = '';
                    input.removeAttribute('data-converted-from');
                });
            }

            if (searchResults) {
                searchResults.innerHTML = '';
                searchResults.style.display = 'none';
            }
            if (quantityForm) quantityForm.style.display = 'none';
        }

        // Delete ingredient
        if (ingredientsList) {
            ingredientsList.addEventListener('click', async function(e) {
                const deleteBtn = e.target.closest('.btn-delete-ingredient');
                if (!deleteBtn) return;

                if (!confirm('Remove this ingredient?')) return;

                const ingredientId = deleteBtn.dataset.ingredientId;

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    const response = await fetch('/MealPlan/RemoveIngredientFromMeal', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: new URLSearchParams({
                            mealId: mealId,
                            ingredientId: ingredientId,
                            __RequestVerificationToken: token
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message || 'Failed to remove ingredient');
                    }
                } catch (error) {
                    console.error('Error removing ingredient:', error);
                    alert('Failed to remove ingredient');
                }
            });
        }

        // Unit conversion
        if (unitSelector) {
            unitSelector.addEventListener('change', function() {
                const selectedUnit = this.value;
                convertAllIngredients(selectedUnit);
            });
        }

        function convertAllIngredients(targetUnit) {
            const items = ingredientsList.querySelectorAll('.recipe-ingredient-item');

            items.forEach(item => {
                const quantitySpan = item.querySelector('.ingredient-quantity');
                if (!quantitySpan) return;

                if (targetUnit === 'original') {
                    quantitySpan.textContent = item.dataset.originalFormatted;
                } else {
                    const value = parseFloat(item.dataset[targetUnit]);
                    quantitySpan.textContent = formatQuantity(value, targetUnit);
                }
            });
        }

        function formatQuantity(quantity, unit) {
            const formats = {
                'teaspoons': `${quantity.toFixed(1)} tsp`,
                'tablespoons': `${quantity.toFixed(1)} tbsp`,
                'cups': `${quantity.toFixed(2)} cups`,
                'coffeecups': `${quantity.toFixed(2)} coffee cups`,
                'millilitres': `${quantity.toFixed(0)} ml`,
                'grams': `${quantity.toFixed(1)} g`
            };
            return formats[unit] || `${quantity.toFixed(1)} g`;
        }
    })();
</script>
