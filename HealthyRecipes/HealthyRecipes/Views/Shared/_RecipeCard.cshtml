@model HealthyRecipes.Web.ViewModels.Recipe.RecipeCardViewModel

<div class="card">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="Recipe image" class="card-img" />
    }
    else
    {
        <div class="card-img-placeholder">🥗</div>
    }
    <div class="card-body">
        <div class="tags" style="margin-bottom:8px;">
            @foreach (var cat in Model.CategoryNames.Take(2))
            {
                <span class="tag">@cat</span>
            }
            @if (Model.Difficulty.HasValue)
            {
                <span class="diff-@Model.Difficulty.ToString()!.ToLower()">@Model.Difficulty</span>
            }
        </div>

        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@Model.Id">
            <div class="card-title">@(Model.Info.Length > 80 ? Model.Info[..80] + "…" : Model.Info)</div>
        </a>

        <div class="macro-row" style="margin: 10px 0;">
            <span class="macro-pill cal">🔥 @Model.Calories.ToString("F0") kcal</span>
            <span class="macro-pill protein">P @Model.Protein.ToString("F0")g</span>
            <span class="macro-pill carbs">C @Model.Carbs.ToString("F0")g</span>
            <span class="macro-pill fat">F @Model.Fat.ToString("F0")g</span>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:14px;">
            <div>
                <span class="stars">@string.Concat(Enumerable.Repeat("★", (int)Math.Round(Model.AverageRating)))</span>
                <span style="font-size:0.8rem; color:var(--muted);">(@Model.RatingCount)</span>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
                @if (Model.PrepTime.HasValue)
                {
                    <span style="font-size:0.8rem; color:var(--muted);">⏱ @Model.PrepTime min</span>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Recipe" asp-action="ToggleSave" asp-route-id="@Model.Id" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-save @(Model.IsSaved ? "saved" : "")">
                            @(Model.IsSaved ? "♥" : "♡")
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
